---
interface Props {
  title: string;
  description?: string;
  type?: string;
  image?: string;
}

const { 
  title, 
  description = "Decoding Chinese internet memes for the world. From 2000 to today, explained in English.",
  type = "website",
  image = "https://cnmemes.com/og-image.png"
} = Astro.props;

const canonicalURL = Astro.url.href;
const fullTitle = `${title} | CNMemes`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="google-site-verification" content="m_VyuVHeGPfVKUHEIclR2a9zv_E8uSWMJPpCBD3P3uY" />
  <meta name="google-adsense-account" content="ca-pub-9126709577750935" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={canonicalURL} />
  <link rel="alternate" hreflang="zh-Hans" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="CNMemes — Chinese Meme Dictionary" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={image} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="CNMemes — The Chinese Internet Meme Dictionary" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:site" content="@cnmemes" />
  <meta name="twitter:image" content={image} />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9W4F0BEMB5"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-9W4F0BEMB5');
  </script>

  <!-- Content Security Policy -->
  <meta http-equiv="Content-Security-Policy" content="
    default-src 'self';
    script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://pagead2.googlesyndication.com https://www.google-analytics.com;
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
    img-src 'self' data: https:;
    font-src 'self' https://fonts.gstatic.com;
    frame-src https://googleads.g.doubleclick.net;
    connect-src 'self' https://www.google-analytics.com https://pagead2.googlesyndication.com;
  " />

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9126709577750935" crossorigin="anonymous"></script>

  <!-- Organization structured data (global E-E-A-T signal) -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CNMemes",
      "alternateName": "中文梗典",
      "url": "https://cnmemes.com",
      "description": "The most complete English-language dictionary of Chinese internet memes, from 2000 to today.",
      "foundingDate": "2024",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "whycici@gmail.com",
        "contactType": "customer support"
      },
      "sameAs": [
        "https://cnmemes.com"
      ]
    }
  </script>

  <!-- Favicon & Feed -->
  <link rel="alternate" type="application/rss+xml" title="CNMemes — Chinese Meme Dictionary" href="https://cnmemes.com/rss.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#c23b22" />

  <!-- Prevent dark mode flash -->
  <script is:inline>
    (function(){
      if (localStorage.getItem('theme') === 'dark')
        document.documentElement.setAttribute('data-theme','dark');
    })();
  </script>

  <!-- Fonts: preconnect + non-blocking load -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Only load fonts actually used: Noto Serif SC (display/Chinese) + Source Sans 3 (body) -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@700&display=swap" media="print" onload="this.media='all'" />
<noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@700&display=swap" />
  </noscript>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <span class="logo-cn">中文梗典</span>
        <span class="logo-divider"></span>
        <span class="logo-en">CNMemes</span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/top-memes">Top Memes</a>
        <a href="/image-memes">Image Memes</a>
        <a href="/platforms">Platforms</a>
        <a href="/about">About</a>
        <button id="themeToggle" aria-label="Toggle dark mode" class="theme-btn">🌙</button>
      </nav>
    </div>
  </header>

  <script>
    // Dark mode: persist preference, default light
    const toggle = document.getElementById('themeToggle');
    const root = document.documentElement;

    function applyTheme(dark) {
      root.setAttribute('data-theme', dark ? 'dark' : 'light');
      if (toggle) toggle.textContent = dark ? '☀️' : '🌙';
    }

    const stored = localStorage.getItem('theme');
    applyTheme(stored === 'dark');

    toggle?.addEventListener('click', () => {
      const isDark = root.getAttribute('data-theme') === 'dark';
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
      applyTheme(!isDark);
    });
  </script>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-links">
        <div style="flex:2;min-width:220px;max-width:480px;">
          <div class="footer-col-title">Browse by Topic</div>
          <div class="footer-col-links">
            <a href="/tag/workplace">Workplace</a>
            <a href="/tag/burnout">Burnout</a>
            <a href="/tag/romance">Romance</a>
            <a href="/tag/identity">Identity</a>
            <a href="/tag/fandom">Fandom</a>
            <a href="/tag/consumerism">Consumerism</a>
            <a href="/tag/self-deprecation">Self-Deprecation</a>
            <a href="/tag/technology">Technology</a>
            <a href="/tag/gaming">Gaming</a>
            <a href="/tag/education">Education</a>
            <a href="/tag/politics">Politics</a>
            <a href="/tag/humor">Humor</a>
            <a href="/tag/internet-culture">Internet Culture</a>
            <a href="/tag/lifestyle">Lifestyle</a>
          </div>
        </div>
        <div style="flex-shrink:0;text-align:left;">
          <div class="footer-col-title">Pages</div>
          <div class="footer-col-links">
            <a href="/memes">All Memes</a>
            <a href="/top-memes">Top Memes</a>
            <a href="/image-memes">Image Memes</a>
            <a href="/platforms">Platforms</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
      <div class="footer-copy">
        <p>CNMemes.com — The English-language dictionary of Chinese internet memes</p>
        <p style="margin-top:4px;">© {new Date().getFullYear()} CNMemes · Updated monthly · <a href="mailto:whycici@gmail.com">whycici@gmail.com</a></p>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
