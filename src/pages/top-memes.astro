---
import Base from '../layouts/Base.astro';
import MemeCard from '../components/MemeCard.astro';
import memes from '../data/memes.json';

const topMemes = [...memes]
  .filter(m => m.popularity === 5)
  .sort((a, b) => b.year - a.year);

const byYear = topMemes.reduce((acc, m) => {
  acc[m.year] = acc[m.year] || [];
  acc[m.year].push(m);
  return acc;
}, {} as Record<number, typeof topMemes>);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
const examples = topMemes.slice(0, 5).map(m => m.english_name).join(', ');

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Top Chinese Internet Memes — Most Popular Slang Explained",
  "description": `The most viral Chinese internet memes explained in English. ${topMemes.length} must-know memes including ${examples} and more.`,
  "url": "https://cnmemes.com/top-memes",
  "hasPart": topMemes.slice(0, 10).map(m => ({
    "@type": "DefinedTerm",
    "name": m.chinese_name,
    "alternateName": m.english_name,
    "url": `https://cnmemes.com/meme/${m.slug}`
  }))
};
---

<Base
  title="Top Chinese Internet Memes — Most Viral Slang Explained in English"
  description={`The most viral Chinese internet memes explained in English. ${topMemes.length} must-know memes from 2000 to today — from 内卷 to yyds, each with cultural context and examples.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <section class="hero">
    <h1>Top Chinese Internet Memes</h1>
    <p>The <strong>{topMemes.length} most viral</strong> Chinese internet memes — rated ★★★★★ — explained in English with cultural context.</p>
    <div class="search-box" style="margin-top:20px;">
      <input type="text" id="topSearch" placeholder="Search top memes..." autocomplete="off" aria-label="Search top memes" />
    </div>
  </section>

  <div class="container" style="padding-top:28px;">

    <!-- Quick nav by year -->
    <div class="year-pills" id="yearNav" style="margin-bottom:36px;">
      {years.map(y => (
        <a href={`#year-${y}`} class="year-pill">{y} ({byYear[y].length})</a>
      ))}
    </div>

    <!-- Grouped by year -->
    <div id="topGrid">
    {years.map(y => (
      <div id={`year-${y}`} class="year-group" style="margin-bottom:56px;">
        <div class="year-heading">
          <h2>{y}</h2>
          <span class="year-count">{byYear[y].length} memes</span>
        </div>
        <div class="meme-grid">
          {byYear[y].map(m => (
            <MemeCard
              slug={m.slug}
              chinese_name={m.chinese_name}
              english_name={m.english_name}
              pinyin={m.pinyin}
              english_explanation={m.english_explanation}
              year={m.year}
              status={m.status}
              tags={m.tags}
              popularity={m.popularity}
            />
          ))}
        </div>
      </div>
    ))}
    </div>

    <!-- Search results (hidden by default) -->
    <div id="searchResults" class="meme-grid" style="display:none;"></div>
    <div id="noResults" style="display:none;text-align:center;padding:40px;color:var(--text-dim);">No memes found matching your search.</div>

  </div>

  <script define:vars={{ topMemes }}>
    const input = document.getElementById('topSearch');
    const topGrid = document.getElementById('topGrid');
    const searchResults = document.getElementById('searchResults');
    const noResults = document.getElementById('noResults');
    const yearNav = document.getElementById('yearNav');

    input.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      if (!q) {
        topGrid.style.display = '';
        yearNav.style.display = '';
        searchResults.style.display = 'none';
        searchResults.innerHTML = '';
        noResults.style.display = 'none';
        return;
      }

      topGrid.style.display = 'none';
      yearNav.style.display = 'none';
      const matched = topMemes.filter(m => {
        const h = [m.chinese_name, m.english_name, m.pinyin, m.english_explanation, ...m.tags].join(' ').toLowerCase();
        return h.includes(q);
      });

      if (matched.length === 0) {
        searchResults.style.display = 'none';
        noResults.style.display = 'block';
      } else {
        noResults.style.display = 'none';
        searchResults.innerHTML = matched.map(m => `
          <div class="meme-card-wrap">
            <a href="/meme/${m.slug}" class="meme-card">
              <div class="card-cn">${m.chinese_name}</div>
              <div class="card-en">${m.english_name}</div>
              <div class="card-pinyin">${m.pinyin}</div>
              <div class="card-excerpt">${m.english_explanation.slice(0, 140)}...</div>
            </a>
            <div class="card-meta">
              <span class="tag tag-year">${m.year}</span>
              <span class="popularity-stars">★★★★★</span>
            </div>
          </div>
        `).join('');
        searchResults.style.display = 'grid';
      }
    });
  </script>
</Base>

<style>
.year-heading {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 2px solid var(--accent);
}

.year-heading h2 {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 700;
  color: var(--text);
}

.year-count {
  font-size: 13px;
  color: var(--text-muted);
}
</style>
