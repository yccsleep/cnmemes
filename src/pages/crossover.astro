---
import Base from '../layouts/Base.astro';

const pairs = [
  {
    en: {
      term: "Slay",
      def: "To absolutely nail something — look amazing, perform brilliantly, or dominate a situation without breaking a sweat.",
      tag: "Praise"
    },
    zh: { term: "绝绝子", pinyin: "juéjuézi", slug: "jue-jue-zi",
      match: "The same energy — when something is so good it breaks the adjective scale. A 2021 intensifier that went everywhere." }
  },
  {
    en: {
      term: "GOAT",
      def: "Greatest Of All Time — the highest possible compliment, used for athletes, artists, or anyone who's simply the best ever.",
      tag: "Praise"
    },
    zh: { term: "yyds", pinyin: "yǒngyuǎn dì shén", slug: "yong-yuan-de-shen",
      match: "Direct equivalent. Short for 永远的神 (eternal god). Used across fandoms exactly like GOAT — even casually for food." }
  },
  {
    en: {
      term: "IYKYK",
      def: "If You Know, You Know — a knowing wink at an inside joke or shared experience. Non-members not invited.",
      tag: "Internet culture"
    },
    zh: { term: "你懂的", pinyin: "nǐ dǒng de", slug: "ni-dong-de",
      match: "\"You know what I mean\" — the same unspoken communication, often used for things that can't be said too explicitly online." }
  },
  {
    en: {
      term: "Unhinged / Going feral",
      def: "Abandoning rational behavior in response to stress — posting uncontrollably, sending walls of text, losing composure dramatically.",
      tag: "Online behavior"
    },
    zh: { term: "发疯文学", pinyin: "fā fēng wénxué", slug: "fa-feng-wen-xue",
      match: "\"Unhinged literature\" — the genre of manic, stream-of-consciousness internet posts when someone snaps. A full aesthetic." }
  },
  {
    en: {
      term: "Hustle culture",
      def: "The glorification of grinding 24/7 — treating overwork as a personality, a virtue, and a competitive sport.",
      tag: "Work & Burnout"
    },
    zh: { term: "内卷", pinyin: "nèijuǎn", slug: "nei-juan",
      match: "Same trap, different angle. 内卷 emphasizes the futility — everyone runs harder and nobody gets ahead. No glamour, just loss." }
  },
  {
    en: {
      term: "Quiet quitting",
      def: "Doing the bare minimum at work — still showing up, but mentally checked out. A refusal to overperform for no reward.",
      tag: "Work & Burnout"
    },
    zh: { term: "摸鱼", pinyin: "mō yú", slug: "mo-yu",
      match: "\"Fishing\" at the office — secretly slacking on company time. Older, funnier, and less philosophical than quiet quitting." }
  },
  {
    en: {
      term: "Let it rot",
      def: "Giving up on trying — accepting failure and leaning into it, often as a dark-humored response to burnout.",
      tag: "Work & Burnout"
    },
    zh: { term: "摆烂", pinyin: "bǎilàn", slug: "bai-lan",
      match: "\"Embrace the rot\" — the same intentional self-destruction. One of the most popular Chinese Gen Z attitudes of 2022." }
  },
  {
    en: {
      term: "Burnout",
      def: "Complete emotional and physical exhaustion from chronic overwork — when you can no longer produce, feel, or care.",
      tag: "Work & Burnout"
    },
    zh: { term: "精神内耗", pinyin: "jīngshén nèihào", slug: "jing-shen-nei-hao",
      match: "\"Mental involution\" — the internal drain from overthinking and self-conflict, not just overwork. Burnout from the inside out." }
  },
  {
    en: {
      term: "Toxic positivity",
      def: "Forcing relentless optimism that dismisses real pain — \"good vibes only\" as a way to avoid difficult truths.",
      tag: "Social behavior"
    },
    zh: { term: "正能量", pinyin: "zhèng néngliàng", slug: "zheng-neng-liang",
      match: "\"Positive energy\" — originally official state language for approved attitudes. Now used ironically to mock forced cheerfulness." }
  },
  {
    en: {
      term: "Rizz",
      def: "Natural charisma — the effortless ability to attract, charm, or flirt without seeming to try.",
      tag: "Dating"
    },
    zh: { term: "撩", pinyin: "liāo", slug: "liao",
      match: "The verb for skilled flirting — to tease or charm someone romantically. 撩 captures the active, effortless side of rizz." }
  },
  {
    en: {
      term: "Gaslighting",
      def: "Psychologically manipulating someone into questioning their own reality — making them doubt their perceptions and sanity.",
      tag: "Dating / Work"
    },
    zh: { term: "职场PUA", pinyin: "zhíchǎng PUA", slug: "zhi-chang-pua",
      match: "\"Workplace PUA\" — Chinese internet borrowed PUA from Western pickup culture and reapplied it to manipulative bosses and managers." }
  },
  {
    en: {
      term: "Red flag",
      def: "A clear warning sign that someone is a bad partner — behavior that should end a relationship immediately.",
      tag: "Dating"
    },
    zh: { term: "渣男", pinyin: "zhā nán", slug: "zha-nan",
      match: "\"Trash man\" — not a warning but a verdict. You use 渣男 after you already know, not as a caution." }
  },
  {
    en: {
      term: "Player / Serial dater",
      def: "Someone who pursues multiple romantic interests simultaneously while hiding this from each of them.",
      tag: "Dating"
    },
    zh: { term: "海王", pinyin: "hǎiwáng", slug: "hai-wang",
      match: "\"Aquaman\" — rules many seas (relationships) at once. A more poetic, meme-ready way to describe the same behavior." }
  },
  {
    en: {
      term: "Stan / Stan culture",
      def: "Intense, often organized fan obsession — from the Eminem song about a fan who took it too far.",
      tag: "Fandom"
    },
    zh: { term: "饭圈", pinyin: "fànquān", slug: "fan-quan",
      match: "\"Fan circle\" — China's version is far more organized, with coordinated voting armies, strict hierarchies, and real money flows." }
  },
  {
    en: {
      term: "Cancel (an idol)",
      def: "Publicly withdrawing support from a celebrity or public figure after a scandal or controversy.",
      tag: "Fandom"
    },
    zh: { term: "塌房", pinyin: "tā fáng", slug: "ta-fang",
      match: "\"The house collapsed\" — when an idol's image crumbles. More visceral than cancel — the entire fandom structure falls." }
  },
  {
    en: {
      term: "Main character energy",
      def: "Acting like the protagonist of your own story — taking up space, drawing attention, living cinematically.",
      tag: "Identity"
    },
    zh: { term: "显眼包", pinyin: "xiǎnyǎn bāo", slug: "xian-yan-bao",
      match: "\"Attention magnet\" — always the most visible person in the room. Usually affectionate teasing, not aspirational like the English version." }
  },
  {
    en: {
      term: "Social anxiety",
      def: "Fear of social situations — often worn as a relatable badge online by people who'd rather stay home.",
      tag: "Identity"
    },
    zh: { term: "社恐", pinyin: "shè kǒng", slug: "she-kong",
      match: "Short for 社交恐惧症. Self-diagnosed by millions online — wearing social fear as an identity the same way the English term does." }
  },
  {
    en: {
      term: "Good vibes / Effortless cool",
      def: "A relaxed, unforced aura — being at ease in any situation without appearing to try.",
      tag: "Lifestyle"
    },
    zh: { term: "松弛感", pinyin: "sōngchí gǎn", slug: "song-chi-gan",
      match: "\"Relaxed aura\" — a 2023 aesthetic ideal. The quality of being comfortable and unhurried that everyone wanted and nobody could fake." }
  },
  {
    en: {
      term: "Chronically online",
      def: "Spending so much time on the internet that you lose touch with offline reality — online logic becomes your default.",
      tag: "Online behavior"
    },
    zh: { term: "死宅", pinyin: "sǐ zhái", slug: "si-zhai",
      match: "\"Hardcore homebody\" — doesn't leave the house, lives online. More about physical shut-in behavior than just internet logic." }
  },
];

const tags = [...new Set(pairs.map(p => p.en.tag))];
---

<Base
  title="English Internet Slang — Chinese Meme Equivalents | CNMemes"
  description={`${pairs.length} English internet slang terms — slay, GOAT, rizz, hustle culture — each matched to its Chinese meme equivalent with cultural context.`}
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "English Internet Slang — Chinese Meme Equivalents",
    "description": `${pairs.length} English internet slang terms matched to their Chinese meme equivalents.`,
    "url": "https://cnmemes.com/crossover"
  })} />

  <section class="hero" style="padding-bottom:28px;">
    <h1>English Slang → <span class="cn-part">Chinese Meme</span></h1>
    <p>{pairs.length} English internet terms — each matched to its Chinese equivalent. Same feeling, different corner of the internet.</p>
  </section>

  <div class="container">

    <!-- Tag filter pills -->
    <div class="year-pills" style="margin-bottom:32px;">
      <button class="year-pill active" data-filter="all">All</button>
      {tags.map(t => (
        <button class="year-pill" data-filter={t}>{t}</button>
      ))}
    </div>

    <div class="crossover-grid" id="crossoverGrid">
      {pairs.map(p => (
        <div class="crossover-card" data-tag={p.en.tag}>
          <div class="en-block">
            <div class="en-header">
              <span class="en-term">{p.en.term}</span>
              <span class="en-tag">{p.en.tag}</span>
            </div>
            <p class="en-def">{p.en.def}</p>
          </div>

          <div class="zh-block">
            <div class="zh-label">Chinese equivalent</div>
            <div class="zh-header">
              <a href={`/meme/${p.zh.slug}`} class="zh-term">{p.zh.term}</a>
              <span class="zh-pinyin">{p.zh.pinyin}</span>
            </div>
            <p class="zh-match">{p.zh.match}</p>
            <a href={`/meme/${p.zh.slug}`} class="zh-readmore">Full explanation →</a>
          </div>
        </div>
      ))}
    </div>

    <div class="crossover-footer">
      <p>Explore more Chinese internet culture by topic</p>
      <div class="crossover-footer-links">
        <a href="/top-memes" class="year-pill">Top Memes</a>
        <a href="/tag/workplace" class="year-pill">Workplace</a>
        <a href="/tag/burnout" class="year-pill">Burnout</a>
        <a href="/tag/romance" class="year-pill">Romance</a>
        <a href="/tag/fandom" class="year-pill">Fandom</a>
        <a href="/tag/internet-culture" class="year-pill">Internet Culture</a>
      </div>
    </div>

  </div>

  <script>
    const btns = document.querySelectorAll('[data-filter]');
    const cards = document.querySelectorAll('[data-tag]');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const f = btn.dataset.filter;
        cards.forEach(c => {
          (c as HTMLElement).style.display = (f === 'all' || c.dataset.tag === f) ? '' : 'none';
        });
      });
    });
  </script>
</Base>

<style>
.crossover-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(520px, 1fr));
  gap: 16px;
  margin-bottom: 48px;
}

.crossover-card {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: box-shadow var(--transition), border-color var(--transition);
}

.crossover-card:hover {
  box-shadow: var(--shadow);
  border-color: var(--accent-border);
}

/* English block — primary */
.en-block {
  padding: 22px 24px 18px;
}

.en-header {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.en-term {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.15;
}

.en-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text-muted);
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: 50px;
  padding: 2px 9px;
  white-space: nowrap;
}

.en-def {
  font-size: 14px;
  color: var(--text-dim);
  line-height: 1.7;
  margin: 0;
}

/* Chinese block — secondary, visually distinct */
.zh-block {
  background: var(--bg-subtle);
  border-top: 1.5px solid var(--border-subtle);
  padding: 16px 24px 18px;
  position: relative;
}

.zh-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 8px;
}

.zh-header {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}

.zh-term {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--accent);
  text-decoration: none;
  line-height: 1.2;
  transition: opacity var(--transition);
}

.zh-term:hover {
  opacity: 0.75;
  text-decoration: none;
}

.zh-pinyin {
  font-size: 13px;
  color: var(--text-muted);
  font-style: italic;
}

.zh-match {
  font-size: 13.5px;
  color: var(--text-dim);
  line-height: 1.65;
  margin: 0 0 10px;
}

.zh-readmore {
  font-size: 12px;
  font-weight: 700;
  color: var(--accent);
  text-decoration: none;
  letter-spacing: 0.3px;
  transition: opacity var(--transition);
}

.zh-readmore:hover {
  opacity: 0.7;
  text-decoration: none;
}

.crossover-footer {
  text-align: center;
  padding: 40px 0 20px;
  border-top: 1px solid var(--border);
}

.crossover-footer p {
  font-size: 14px;
  color: var(--text-dim);
  margin-bottom: 16px;
}

.crossover-footer-links {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .crossover-grid {
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .en-block { padding: 18px 18px 14px; }
  .zh-block { padding: 14px 18px 16px; }
  .en-term { font-size: 19px; }
  .zh-term { font-size: 18px; }
}
</style>
