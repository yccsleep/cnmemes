---
import Base from '../../layouts/Base.astro';
import MemeCard from '../../components/MemeCard.astro';
import memes from '../../data/memes.json';

export function getStaticPaths() {
  return memes.map(m => ({
    params: { slug: m.slug },
    props: { meme: m }
  }));
}

const { meme } = Astro.props;
const statusClass = meme.status === 'still popular' ? 'popular' : meme.status === 'fading' ? 'fading' : 'classic';

// Era-aware year page link
const getPageYear = (y: number) => y >= 2015 ? y : y <= 2004 ? 2004 : y <= 2009 ? 2009 : 2014;
const eraLabels: Record<number, string> = { 2004: '2000–2004', 2009: '2005–2009', 2014: '2010–2014' };
const pageYear = getPageYear(meme.year);
const yearLabel = eraLabels[pageYear] || String(meme.year);

// Related memes: prioritise same tag, then fill with high-popularity same-era memes
const sameTagMemes = memes.filter(m =>
  m.slug !== meme.slug && m.tags.some(t => meme.tags.includes(t))
).sort((a, b) => b.popularity - a.popularity);

const fillMemes = memes.filter(m =>
  m.slug !== meme.slug &&
  !sameTagMemes.find(s => s.slug === m.slug) &&
  Math.abs(getPageYear(m.year) - pageYear) <= 1
).sort((a, b) => b.popularity - a.popularity);

const related = [...sameTagMemes, ...fillMemes].slice(0, 4);

const pageTitle = `${meme.chinese_name} Meaning — ${meme.english_name} | Chinese Internet Meme`;
const pageDesc = `What does ${meme.chinese_name} (${meme.pinyin}) mean? It means "${meme.english_name}" — ${meme.english_explanation.slice(0, 110)}...`;

// FAQ schema
const faqItems: any[] = [
  {
    "@type": "Question",
    "name": `What does ${meme.chinese_name} mean in Chinese?`,
    "acceptedAnswer": { "@type": "Answer", "text": meme.english_explanation }
  },
  {
    "@type": "Question",
    "name": `What is the cultural context of ${meme.chinese_name}?`,
    "acceptedAnswer": { "@type": "Answer", "text": meme.cultural_context }
  },
  {
    "@type": "Question",
    "name": `How do you pronounce ${meme.chinese_name}?`,
    "acceptedAnswer": { "@type": "Answer", "text": `${meme.chinese_name} is pronounced "${meme.pinyin}" in Mandarin Chinese.` }
  }
];

if (meme.origin_story) {
  faqItems.push({
    "@type": "Question",
    "name": `Where did ${meme.chinese_name} come from?`,
    "acceptedAnswer": { "@type": "Answer", "text": meme.origin_story }
  });
}

const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqItems };
const definedTermSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": meme.chinese_name,
  "alternateName": [meme.english_name, meme.pinyin],
  "description": meme.english_explanation,
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": "CNMemes — Chinese Internet Meme Dictionary",
    "url": "https://cnmemes.com"
  },
  "url": `https://cnmemes.com/meme/${meme.slug}`
};
---

<Base title={pageTitle} description={pageDesc}>
  <div class="meme-detail">
    <!-- Breadcrumb with correct era-aware link -->
    <div class="breadcrumb">
      <a href="/">Home</a><span>›</span>
      <a href={`/year/${pageYear}`}>{yearLabel}</a><span>›</span>
      {meme.chinese_name}
    </div>

    <div class="meme-header">
      <h1 class="cn-name">{meme.chinese_name} — {meme.english_name}</h1>
      <div class="pinyin">{meme.pinyin}</div>
      <div class="meta-row">
        <a href={`/year/${pageYear}`} class="tag tag-year">{yearLabel}</a>
        <span class={`tag tag-${statusClass}`}>{meme.status}</span>
        <span class="stars-display" title={`Popularity: ${meme.popularity}/5`}>{'★'.repeat(meme.popularity)}{'☆'.repeat(5-meme.popularity)}</span>
        {meme.tags.map(t => <a href={`/tag/${t}`} class="tag tag-topic">{t}</a>)}
      </div>
    </div>

    <div class="meme-section">
      <h2 class="section-title">What Does {meme.chinese_name} Mean?</h2>
      <p>{meme.english_explanation}</p>
    </div>

    {meme.origin_story && (
      <div class="meme-section">
        <h2 class="section-title">Origin Story</h2>
        <p>{meme.origin_story}</p>
      </div>
    )}

    <div class="meme-section">
      <h2 class="section-title">Cultural Context</h2>
      <p>{meme.cultural_context}</p>
    </div>

    {meme.similar_expressions && (
      <div class="meme-section">
        <h2 class="section-title">Similar Expressions in English</h2>
        <p>{meme.similar_expressions}</p>
      </div>
    )}

    <div class="meme-section">
      <h2 class="section-title">How Is It Used?</h2>
      {meme.examples.map(ex => (
        <div class="example-block">
          <div class="example-cn">{ex.chinese}</div>
          <div class="example-en">{ex.english}</div>
        </div>
      ))}
    </div>

    <div class="meme-section">
      <h2 class="section-title">Chinese Explanation (中文解释)</h2>
      <p class="cn-explanation">{meme.chinese_explanation}</p>
    </div>

    {related.length > 0 && (
      <div class="meme-section" style="margin-top:48px;">
        <h2 class="section-title">Related Chinese Memes</h2>
        <div class="related-grid">
          {related.map(m => (
            <MemeCard
              slug={m.slug}
              chinese_name={m.chinese_name}
              english_name={m.english_name}
              pinyin={m.pinyin}
              english_explanation={m.english_explanation}
              year={m.year}
              status={m.status}
              tags={m.tags}
              popularity={m.popularity}
            />
          ))}
        </div>
      </div>
    )}

    <!-- Share buttons -->
    <div class="share-section">
      <div class="share-label">Share this meme</div>
      <div class="share-buttons">
        <button class="share-btn share-x" id="shareX">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Share on X
        </button>
        <button class="share-btn share-reddit" id="shareReddit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
          Share on Reddit
        </button>
        <button class="share-btn share-copy" id="copyLink">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <span id="copyLinkText">Copy Link</span>
        </button>
      </div>
    </div>

    <!-- Explore more internal links -->
    <div class="explore-more">
      <span>Explore more:</span>
      <a href={`/year/${pageYear}`} class="tag tag-year">{yearLabel} memes →</a>
      {meme.tags.map(t => (
        <a href={`/tag/${t}`} class="tag tag-topic">{t} →</a>
      ))}
      <a href="/top-memes" class="tag tag-topic">Top Memes →</a>
      <a href="/" class="tag tag-topic">All memes →</a>
    </div>
  </div>
</Base>

<script define:vars={{ meme }}>
  const pageUrl = window.location.href;

  document.getElementById('shareX').addEventListener('click', () => {
    const text = encodeURIComponent(`Did you know? ${meme.chinese_name} (${meme.pinyin}) = "${meme.english_name}"\n\n${meme.english_explanation.slice(0, 120)}...\n\n#ChineseMeme #LearnChinese`);
    const url = encodeURIComponent(pageUrl);
    window.open(`https://x.com/intent/post?text=${text}&url=${url}`, '_blank');
  });

  document.getElementById('shareReddit').addEventListener('click', () => {
    const title = encodeURIComponent(`TIL: ${meme.chinese_name} (${meme.english_name}) — Chinese internet meme explained`);
    const url = encodeURIComponent(pageUrl);
    window.open(`https://www.reddit.com/submit?url=${url}&title=${title}`, '_blank');
  });

  document.getElementById('copyLink').addEventListener('click', () => {
    navigator.clipboard.writeText(pageUrl).then(() => {
      const btn = document.getElementById('copyLinkText');
      btn.textContent = 'Copied!';
      document.getElementById('copyLink').classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'Copy Link';
        document.getElementById('copyLink').classList.remove('copied');
      }, 2000);
    });
  });
</script>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)} />
