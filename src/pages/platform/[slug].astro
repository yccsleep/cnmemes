---
import Base from '../../layouts/Base.astro';
import MemeCard from '../../components/MemeCard.astro';
import memes from '../../data/memes.json';
import platforms from '../../data/platforms.json';

export function getStaticPaths() {
  return platforms.map(p => ({
    params: { slug: p.slug },
    props: { platform: p }
  }));
}

const { platform } = Astro.props;

const platformMemes = memes
  .filter(m => (m as any).platform === platform.slug)
  .sort((a, b) => b.year - a.year || b.popularity - a.popularity);

const byYear = platformMemes.reduce((acc, m) => {
  acc[m.year] = acc[m.year] || [];
  acc[m.year].push(m);
  return acc;
}, {} as Record<number, typeof platformMemes>);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const statusLabel: Record<string, string> = {
  active: 'Active',
  declining: 'Declining',
  legacy: 'Legacy'
};
const statusClass: Record<string, string> = {
  active: 'p-status-active',
  declining: 'p-status-fading',
  legacy: 'p-status-legacy'
};

const pageTitle = `${platform.english_name} (${platform.chinese_name}) — Chinese Internet Platform`;
const pageDesc = `${platform.tagline}. ${platform.description.slice(0, 120)}...`;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${platform.english_name} — Chinese Internet Platform`,
  "description": platform.description,
  "url": `https://cnmemes.com/platform/${platform.slug}`
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cnmemes.com" },
    { "@type": "ListItem", "position": 2, "name": "Platforms", "item": "https://cnmemes.com/platforms" },
    { "@type": "ListItem", "position": 3, "name": platform.english_name, "item": `https://cnmemes.com/platform/${platform.slug}` }
  ]
};

// Prev / next platforms
const idx = platforms.findIndex(p => p.slug === platform.slug);
const prevPlatform = platforms[idx > 0 ? idx - 1 : platforms.length - 1];
const nextPlatform = platforms[idx < platforms.length - 1 ? idx + 1 : 0];
---

<Base title={pageTitle} description={pageDesc} type="article">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- Hero -->
  <div class="platform-hero" style={`--p-color:${platform.color};--p-color-light:${platform.color_light};`}>
    <div class="container">

      <div class="breadcrumb">
        <a href="/">Home</a><span>›</span>
        <a href="/platforms">Platforms</a><span>›</span>
        {platform.english_name}
      </div>

      <div class="platform-hero-inner">
        <!-- Logo -->
        <div class="platform-hero-logo">
          <svg viewBox="0 0 24 24" class="platform-hero-icon" aria-hidden="true" set:html={platform.icon_svg ?? `<path fill-rule="evenodd" d="${platform.icon_path}" fill="white"/>`} />
        </div>

        <!-- Main info -->
        <div class="platform-hero-text">
          <div class="platform-hero-badges">
            <span class="p-type-badge">{platform.type}</span>
            <span class={`p-status-badge ${statusClass[platform.status] || 'p-status-active'}`}>
              {statusLabel[platform.status] || platform.status}
            </span>
          </div>
          <h1 class="platform-hero-cn">{platform.chinese_name}</h1>
          <p class="platform-hero-en">{platform.english_name}</p>
          <p class="platform-hero-tagline">"{platform.tagline}"</p>

          <!-- Stats row -->
          <div class="platform-stats-row">
            <div class="platform-stat">
              <span class="stat-label">Founded</span>
              <span class="stat-value">{platform.founded}</span>
            </div>
            <div class="stat-divider" />
            <div class="platform-stat">
              <span class="stat-label">Peak Era</span>
              <span class="stat-value">{platform.peak_years}</span>
            </div>
            <div class="stat-divider" />
            <div class="platform-stat">
              <span class="stat-label">Category</span>
              <span class="stat-value">{platform.type}</span>
            </div>
          </div>

          {platform.url && (
            <a href={platform.url} target="_blank" rel="noopener noreferrer" class="platform-visit-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Visit {platform.english_name}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Body content -->
  <div class="container platform-body">

    <!-- 2-col layout: main (left) + sidebar (right) -->
    <div class="platform-layout">

      <!-- Left: main content -->
      <div class="platform-main">

        <!-- About -->
        <section class="p-section">
          <h2 class="p-section-title">About {platform.english_name}</h2>
          <p class="p-body-text">{platform.description}</p>
        </section>

        <!-- Cultural Context -->
        <section class="p-section">
          <h2 class="p-section-title">Why It Matters for Meme Culture</h2>
          <p class="p-body-text">{platform.cultural_context}</p>
        </section>

        <!-- Known For -->
        <section class="p-section">
          <h2 class="p-section-title">Known For</h2>
          <div class="known-for-grid">
            {platform.known_for.map((item: string) => (
              <div class="known-for-item">
                <span class="known-for-dot" />
                <span>{item}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Memes from this platform -->
        <section class="p-section" style="margin-top:48px;">
          <h2 class="p-section-title">Memes from {platform.english_name}</h2>
          {platformMemes.length > 0 ? (
            years.map(year => (
              <div class="year-group">
                <h3 class="year-group-label">{year}</h3>
                <div class="meme-grid">
                  {byYear[year].map(m => (
                    <MemeCard
                      slug={m.slug} chinese_name={m.chinese_name} english_name={m.english_name}
                      pinyin={m.pinyin} english_explanation={m.english_explanation}
                      year={m.year} status={m.status} tags={m.tags} popularity={m.popularity}
                    />
                  ))}
                </div>
              </div>
            ))
          ) : (
            <div class="no-memes-notice">
              <p>We haven't tagged platform-specific memes yet. Browse all memes and filter by topic to find content related to {platform.english_name} culture.</p>
              <a href="/memes" class="section-more-btn">Browse all memes →</a>
            </div>
          )}
        </section>

      </div>

      <!-- Right: sidebar -->
      <aside class="platform-sidebar">

        <!-- Quick facts -->
        <div class="p-sidebar-card">
          <h3 class="p-sidebar-title">Quick Facts</h3>
          <dl class="p-facts">
            <div class="p-fact-row">
              <dt>Chinese Name</dt>
              <dd class="fact-cn">{platform.chinese_name}</dd>
            </div>
            <div class="p-fact-row">
              <dt>English Name</dt>
              <dd>{platform.english_name}</dd>
            </div>
            <div class="p-fact-row">
              <dt>Type</dt>
              <dd>{platform.type}</dd>
            </div>
            <div class="p-fact-row">
              <dt>Founded</dt>
              <dd>{platform.founded}</dd>
            </div>
            <div class="p-fact-row">
              <dt>Peak Years</dt>
              <dd>{platform.peak_years}</dd>
            </div>
            <div class="p-fact-row">
              <dt>Status</dt>
              <dd>
                <span class={`p-status-badge ${statusClass[platform.status] || 'p-status-active'}`}>
                  {statusLabel[platform.status] || platform.status}
                </span>
              </dd>
            </div>
          </dl>
          {platform.url && (
            <a href={platform.url} target="_blank" rel="noopener noreferrer" class="platform-visit-btn sidebar-visit">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Visit {platform.english_name}
            </a>
          )}
        </div>

        <!-- Other platforms -->
        <div class="p-sidebar-card">
          <h3 class="p-sidebar-title">Other Platforms</h3>
          <div class="other-platforms">
            {platforms.filter(p => p.slug !== platform.slug).map(p => (
              <a href={`/platform/${p.slug}`} class="other-platform-link">
                <div class="other-platform-icon" style={`background-color:${p.color}`}>
                  <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" set:html={p.icon_svg ?? `<path fill-rule="evenodd" d="${p.icon_path}" fill="white"/>`} />
                </div>
                <span>{p.english_name}</span>
                <span class="other-platform-cn">{p.chinese_name}</span>
              </a>
            ))}
          </div>
        </div>

      </aside>
    </div>

    <!-- Prev / Next navigation -->
    <nav class="platform-nav">
      <a href={`/platform/${prevPlatform.slug}`} class="platform-nav-btn platform-nav-prev">
        <span class="platform-nav-dir">← Previous Platform</span>
        <span class="platform-nav-name">{prevPlatform.english_name} · {prevPlatform.chinese_name}</span>
      </a>
      <a href={`/platform/${nextPlatform.slug}`} class="platform-nav-btn platform-nav-next">
        <span class="platform-nav-dir">Next Platform →</span>
        <span class="platform-nav-name">{nextPlatform.english_name} · {nextPlatform.chinese_name}</span>
      </a>
    </nav>

  </div>
</Base>

<style>
/* ─── Hero ─── */
.platform-hero {
  background: var(--bg-subtle);
  border-bottom: 1px solid var(--border);
  padding: 32px 0 40px;
}

.platform-hero-inner {
  display: flex;
  gap: 28px;
  align-items: flex-start;
  margin-top: 16px;
}

.platform-hero-logo {
  width: 80px;
  height: 80px;
  border-radius: 18px;
  background: var(--p-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(0,0,0,0.18);
}
.platform-hero-icon { width: 44px; height: 44px; }

.platform-hero-badges {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.p-type-badge {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-muted);
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  padding: 3px 10px;
  border-radius: 20px;
}

.p-status-active  { background: rgba(22,160,133,0.12); color: #16a085; border-color: rgba(22,160,133,0.3); }
.p-status-fading  { background: rgba(180,130,20,0.12);  color: #b07d10; border-color: rgba(180,130,20,0.3); }
.p-status-legacy  { background: rgba(100,80,180,0.12); color: #6050aa; border-color: rgba(100,80,180,0.3); }

.p-status-badge {
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid;
}

.platform-hero-cn {
  font-size: clamp(26px, 4vw, 42px);
  font-weight: 700;
  font-family: var(--font-display);
  color: var(--p-color);
  margin: 0 0 4px;
  line-height: 1.1;
}

.platform-hero-en {
  font-size: 17px;
  color: var(--text-dim);
  margin: 0 0 10px;
  font-weight: 500;
}

.platform-hero-tagline {
  font-size: 15px;
  font-style: italic;
  color: var(--text-dim);
  margin: 0 0 16px;
  line-height: 1.5;
  max-width: 560px;
}

/* Stats row */
.platform-stats-row {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 20px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  width: fit-content;
}

.platform-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 10px 20px;
}

.stat-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-muted);
}

.stat-value {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
}

.stat-divider {
  width: 1px;
  align-self: stretch;
  background: var(--border);
}

/* Visit button */
.platform-visit-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--p-color);
  border: 1.5px solid var(--p-color);
  padding: 7px 16px;
  border-radius: 20px;
  text-decoration: none;
  transition: all 0.18s ease;
}
.platform-visit-btn:hover {
  background: var(--p-color);
  color: #fff;
  text-decoration: none;
}
.sidebar-visit {
  display: flex;
  justify-content: center;
  margin-top: 12px;
}

/* ─── Body ─── */
.platform-body {
  padding-top: 48px;
  padding-bottom: 80px;
}

.platform-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 48px;
  align-items: start;
}

/* Main sections */
.platform-main { min-width: 0; }

.p-section {
  margin-bottom: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid var(--border-subtle);
}
.p-section:last-child { border-bottom: none; }

.p-section-title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 14px;
  padding-left: 14px;
  border-left: 3px solid var(--p-color, var(--accent));
}

.p-body-text {
  font-size: 15.5px;
  line-height: 1.8;
  color: var(--text-dim);
  margin: 0;
}

/* Known for */
.known-for-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 10px;
}

.known-for-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: var(--bg-subtle);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: 10px 14px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-dim);
  line-height: 1.4;
}

.known-for-dot {
  flex-shrink: 0;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--p-color, var(--accent));
  margin-top: 4px;
}

/* Memes section */
.year-group { margin-bottom: 40px; }
.year-group-label {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-muted);
  margin-bottom: 14px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border-subtle);
}

.meme-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

.no-memes-notice {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px 24px;
  text-align: center;
}
.no-memes-notice p {
  font-size: 14px;
  color: var(--text-dim);
  line-height: 1.6;
  margin: 0 0 16px;
}

.section-more-btn {
  display: inline-block;
  font-size: 14px;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  padding: 8px 20px;
  border: 1.5px solid var(--accent-border);
  border-radius: 50px;
  transition: all 0.18s ease;
}
.section-more-btn:hover {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
  text-decoration: none;
}

/* ─── Sidebar ─── */
.p-sidebar-card {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px;
  margin-bottom: 20px;
}

.p-sidebar-title {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-muted);
  margin-bottom: 14px;
}

/* Quick facts */
.p-facts { margin: 0; }

.p-fact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border-subtle);
  gap: 12px;
}
.p-fact-row:last-child { border-bottom: none; }

.p-fact-row dt {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
  flex-shrink: 0;
}
.p-fact-row dd {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  text-align: right;
  margin: 0;
}
.fact-cn {
  font-family: var(--font-display);
  font-size: 16px !important;
  color: var(--p-color) !important;
}

/* Other platforms list */
.other-platforms {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.other-platform-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 8px;
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: background 0.15s ease;
}
.other-platform-link:hover {
  background: var(--bg-subtle);
  text-decoration: none;
}
.other-platform-link span:nth-child(2) {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  flex: 1;
}
.other-platform-cn {
  font-size: 12px;
  color: var(--text-muted);
}

.other-platform-icon {
  width: 26px;
  height: 26px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ─── Nav ─── */
.platform-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 56px;
  border-top: 1px solid var(--border-subtle);
  padding-top: 24px;
}

.platform-nav-btn {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 16px 20px;
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: all 0.18s ease;
}
.platform-nav-btn:hover {
  border-color: var(--accent-border);
  box-shadow: var(--shadow);
  text-decoration: none;
}
.platform-nav-prev { align-items: flex-start; }
.platform-nav-next { align-items: flex-end; }

.platform-nav-dir {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--accent);
}
.platform-nav-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}

/* ─── Breadcrumb ─── */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 0;
}
.breadcrumb a {
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.15s;
}
.breadcrumb a:hover { color: var(--accent); }
.breadcrumb span { color: var(--border); }

/* ─── Responsive ─── */
@media (max-width: 900px) {
  .platform-hero-inner { flex-direction: column; gap: 20px; }
  .platform-layout { grid-template-columns: 1fr; gap: 32px; }
  .platform-sidebar { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .p-sidebar-card { margin-bottom: 0; }
}

@media (max-width: 600px) {
  .platform-stats-row { flex-wrap: wrap; }
  .platform-nav { grid-template-columns: 1fr; }
  .platform-sidebar { grid-template-columns: 1fr; }
  .known-for-grid { grid-template-columns: 1fr; }
}
</style>
