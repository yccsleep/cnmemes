---
import Base from '../layouts/Base.astro';

// image: 放真实图片路径如 "/stickers/gou-tou.png"，null 则显示占位符
const stickers = [
  {
    slug: "gou-tou",
    name: "狗头",
    pinyin: "gǒutóu",
    english: "Dog Face",
    image: null,
    placeholder: "🐶",
    year: "2018",
    desc: "A yellow cartoon dog face pasted at the end of sarcastic or provocative sentences — the Chinese internet's irony marker. Equivalent to the Western 🙂 used passive-aggressively.",
    usage: "我只是说说而已🐶 (Just saying 🐶) — the dog head signals \"don't take this too seriously.\"",
    tags: ["Sarcasm", "Internet culture"]
  },
  {
    slug: "xiong-mao-tou",
    name: "熊猫头",
    pinyin: "xióng māo tóu",
    english: "Panda Head",
    image: null,
    placeholder: "🐼",
    year: "2012",
    desc: "A shocked panda face photoshopped onto human bodies or placed next to surprising statements. The blank-eyed terror captures the feeling of witnessing something deeply unhinged.",
    usage: "Used as a reaction image whenever someone says or does something completely unexpected.",
    tags: ["Reaction", "Shock"]
  },
  {
    slug: "ke-bo",
    name: "猫猫虫可波",
    pinyin: "māo māo chóng kě bō",
    english: "Capoo / Bug-Cat",
    image: null,
    placeholder: "🐱",
    year: "2020",
    desc: "A round blue bug-cat creature created by Taiwanese artist bug.cat. Became a dominant sticker on Chinese social media — used to express every emotion from joy to existential dread.",
    usage: "One of the most versatile sticker characters — there's a Capoo face for every possible mood.",
    tags: ["Cute", "Versatile"]
  },
  {
    slug: "jia-you-ya",
    name: "加油鸭",
    pinyin: "jiā yóu yā",
    english: "Cheering Duck",
    image: null,
    placeholder: "🦆",
    year: "2018",
    desc: "A tiny yellow duck with pompoms cheering you on. 加油 means \"go go\" or \"hang in there.\" Became the default encouragement sticker — sent whenever someone needs motivation.",
    usage: "Sent to friends before exams, job interviews, or any stressful event.",
    tags: ["Encouragement", "Cute"]
  },
  {
    slug: "da-gong-ren",
    name: "打工人",
    pinyin: "dǎ gōng rén",
    english: "The Wage Slave",
    image: null,
    placeholder: "💼",
    year: "2020",
    desc: "A bleary-eyed silhouette trudging to work against a sunrise, captioned with the phrase 打工人. Became the 2020 meme that defined how an entire generation felt about work: exhausted but resigned.",
    usage: "Sent on Monday mornings, before meetings, or any time work feels meaningless but inescapable.",
    tags: ["Work", "Burnout"]
  },
  {
    slug: "lan-yang-yang",
    name: "懒羊羊",
    pinyin: "lǎn yáng yang",
    english: "Lazy Sheep",
    image: null,
    placeholder: "🐑",
    year: "2015",
    desc: "The laziest character from the Chinese cartoon 《喜羊羊与灰太狼》, repurposed as a meme for anyone who refuses to move, think, or be productive. Peak躺平 energy.",
    usage: "Used to express extreme reluctance, tiredness, or solidarity with slackers everywhere.",
    tags: ["Lazy", "Relatable"]
  },
  {
    slug: "yin-xian-xiao-ren",
    name: "阴险小人",
    pinyin: "yīn xiǎn xiǎo rén",
    english: "Scheming Villain Face",
    image: null,
    placeholder: "😈",
    year: "2013",
    desc: "A pixel-art stickman with a sinister sideways glance and a thin smile. Used when plotting something, gloating, or expressing smug satisfaction — the Chinese internet's ≈ 😏.",
    usage: "Appears whenever someone announces a plan, a revenge, or a mischievous intention.",
    tags: ["Smug", "Plotting"]
  },
  {
    slug: "wu-lian",
    name: "捂脸",
    pinyin: "wǔ liǎn",
    english: "Face Palm / Hide Face",
    image: null,
    placeholder: "🤦",
    year: "2014",
    desc: "A category of stickers where characters (often celebrities, cartoon figures, or user avatars) cover their faces in shame, embarrassment, or exasperation.",
    usage: "The go-to reaction for secondhand embarrassment, cringe moments, or your own mistakes.",
    tags: ["Embarrassment", "Reaction"]
  },
  {
    slug: "sha-diao",
    name: "沙雕",
    pinyin: "shā diāo",
    english: "Sand Sculpture / Absurdist Edit",
    image: null,
    placeholder: "🗿",
    year: "2017",
    desc: "Not one specific image but a whole genre: heavily edited, deliberately low-quality images designed to be funny through sheer absurdity. The Chinese internet equivalent of deep-fried memes.",
    usage: "A 沙雕 edit typically crops a face onto a bizarre body, adds dramatic music overlays, or assembles non-sequitur images into a chaotic collage.",
    tags: ["Absurdist", "Humor"]
  },
  {
    slug: "la-bi-xiao-xin",
    name: "蜡笔小新",
    pinyin: "là bǐ xiǎo xīn",
    english: "Crayon Shin-chan",
    image: null,
    placeholder: "✏️",
    year: "2010",
    desc: "The Japanese cartoon character Shin-chan has been adapted into countless Chinese reaction stickers. His chubby face and chaotic energy make him perfect for expressing unfiltered emotion.",
    usage: "Shin-chan stickers cover the full emotional spectrum — from pure joy to absolute despair.",
    tags: ["Reaction", "Cartoon"]
  },
  {
    slug: "pei-qi",
    name: "小猪佩奇",
    pinyin: "xiǎo zhū pèi qí",
    english: "Peppa Pig",
    image: null,
    placeholder: "🐷",
    year: "2018",
    desc: "Peppa Pig was rebranded as a \"社会人\" (society person) symbol in China — a tattoo of Peppa on your wrist meant you were street-smart and worldly. A bizarre, completely sincere meme.",
    usage: "\"小猪佩奇身上纹，掌声送给社会人\" — Peppa tattooed on the body, applause for the person of society.",
    tags: ["Ironic", "Cultural"]
  },
  {
    slug: "mao-mao",
    name: "猫猫",
    pinyin: "māo māo",
    english: "Cat Reaction Memes",
    image: null,
    placeholder: "😾",
    year: "2019",
    desc: "A sprawling family of cat-based reaction images — from the famous \"woman yelling at cat\" to Chinese-specific cat edits. Cats are the universal internet language; China has its own dialects.",
    usage: "Specific cat faces are matched to specific emotions — the flat-eared angry cat, the smug lounging cat, the confused blinking cat.",
    tags: ["Cats", "Reaction"]
  },
];
---

<Base
  title="Chinese Visual Memes — Sticker & Image Meme Dictionary | CNMemes"
  description={`${stickers.length} iconic Chinese internet stickers and image memes explained — from 狗头 (Dog Face) to 熊猫头 (Panda Head), with context and usage.`}
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Chinese Visual Memes — Sticker & Image Meme Dictionary",
    "description": `${stickers.length} iconic Chinese internet stickers explained in English.`,
    "url": "https://cnmemes.com/stickers"
  })} />

  <section class="hero" style="padding-bottom:28px;">
    <h1>Chinese Internet <span class="cn-part">Sticker Dictionary</span></h1>
    <p>{stickers.length} iconic visual memes and image macros — the faces of Chinese internet, explained.</p>
  </section>

  <div class="container">

    <div class="sticker-intro">
      <p>
        Text memes are only half the story. Chinese internet runs on 表情包 (biǎoqíng bāo) —
        image-based stickers that carry emotion, irony, and cultural meaning impossible to put in words.
        These are the faces you'll see everywhere, from WeChat to Weibo to Douyin.
      </p>
    </div>

    <div class="sticker-grid">
      {stickers.map(s => (
        <div class="sticker-card">
          <div class="sticker-img-wrap">
            {s.image
              ? <img src={s.image} alt={`${s.name} (${s.english}) — Chinese internet sticker`} class="sticker-img" loading="lazy" />
              : <div class="sticker-placeholder">
                  <span class="placeholder-emoji">{s.placeholder}</span>
                  <span class="placeholder-hint">Image coming soon</span>
                </div>
            }
          </div>

          <div class="sticker-body">
            <div class="sticker-header">
              <span class="sticker-cn">{s.name}</span>
              <span class="sticker-year">{s.year}</span>
            </div>
            <div class="sticker-pinyin">{s.pinyin}</div>
            <div class="sticker-en">{s.english}</div>
            <p class="sticker-desc">{s.desc}</p>
            <div class="sticker-usage">
              <span class="usage-label">How it's used</span>
              <p class="usage-text">{s.usage}</p>
            </div>
            <div class="sticker-tags">
              {s.tags.map(t => <span class="tag tag-topic">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</Base>

<style>
.sticker-intro {
  background: var(--bg-subtle);
  border-left: 3px solid var(--accent);
  border-radius: 0 var(--radius) var(--radius) 0;
  padding: 16px 20px;
  margin-bottom: 36px;
  font-size: 15px;
  line-height: 1.75;
  color: var(--text-dim);
}

.sticker-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 20px;
  margin-bottom: 60px;
}

.sticker-card {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: box-shadow var(--transition), border-color var(--transition), transform var(--transition);
}

.sticker-card:hover {
  box-shadow: var(--shadow);
  border-color: var(--accent-border);
  transform: translateY(-2px);
}

/* Image area */
.sticker-img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1.5px solid var(--border-subtle);
  overflow: hidden;
}

.sticker-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 20px;
}

.sticker-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
  height: 100%;
}

.placeholder-emoji {
  font-size: 72px;
  line-height: 1;
  filter: grayscale(0.2);
}

.placeholder-hint {
  font-size: 11px;
  color: var(--text-muted);
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: 600;
}

/* Card body */
.sticker-body {
  padding: 18px 20px 20px;
}

.sticker-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 3px;
}

.sticker-cn {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
}

.sticker-year {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 600;
}

.sticker-pinyin {
  font-size: 12px;
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 2px;
}

.sticker-en {
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 10px;
}

.sticker-desc {
  font-size: 13.5px;
  color: var(--text-dim);
  line-height: 1.65;
  margin: 0 0 12px;
}

.sticker-usage {
  background: var(--surface-raised);
  border: 1px solid var(--border-subtle);
  border-left: 3px solid var(--accent);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  padding: 10px 12px;
  margin-bottom: 12px;
}

.usage-label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 5px;
}

.usage-text {
  font-size: 13px;
  color: var(--text-dim);
  line-height: 1.55;
  margin: 0;
}

.sticker-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .sticker-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .sticker-cn { font-size: 18px; }
  .placeholder-emoji { font-size: 52px; }
  .sticker-body { padding: 14px 14px 16px; }
}

@media (max-width: 480px) {
  .sticker-grid { grid-template-columns: 1fr; }
}
</style>
