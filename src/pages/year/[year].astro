---
import Base from '../../layouts/Base.astro';
import MemeCard from '../../components/MemeCard.astro';
import memes from '../../data/memes.json';

// Era groupings: map each specific year to its representative slug
const eraConfig: Record<number, { slug: number; label: string; years: number[] }> = {
  2004: { slug: 2004, label: '2000–2004', years: [2002, 2003, 2004] },
  2009: { slug: 2009, label: '2005–2009', years: [2005, 2006, 2007, 2008, 2009] },
  2014: { slug: 2014, label: '2010–2014', years: [2010, 2011, 2012, 2013, 2014] },
};

// Only generate pages for: era representative years + 2015 onwards
export function getStaticPaths() {
  const eraReps = new Set([2004, 2009, 2014]);
  const recentYears = [...new Set(memes.map(m => m.year))].filter(y => y >= 2015);
  const allPageYears = [...eraReps, ...recentYears];

  return allPageYears.map(y => ({
    params: { year: String(y) },
    props: { year: y }
  }));
}

const { year } = Astro.props;
const currentYear = Math.max(...memes.map(m => m.year));
const isCurrentYear = year === currentYear;

// Get the right meme set — for era pages, include all years in the era
const era = eraConfig[year];
const displayLabel = era ? era.label : String(year);
const yearMemes = era
  ? memes.filter(m => era.years.includes(m.year)).sort((a, b) => a.year - b.year)
  : memes.filter(m => m.year === year);

const topMemes = yearMemes.filter(m => m.popularity >= 4).slice(0, 5).map(m => m.chinese_name).join('、');

// Build deduplicated pills for navigation
const seen = new Set<string>();
const pills: { label: string; href: string; active: boolean }[] = [];

// Get all unique page years in descending order
const allPageYears = [
  ...new Set([
    ...memes.map(m => m.year >= 2015 ? m.year : (m.year <= 2004 ? 2004 : m.year <= 2009 ? 2009 : 2014))
  ])
].sort((a, b) => b - a);

for (const y of allPageYears) {
  const label = eraConfig[y] ? eraConfig[y].label : String(y);
  if (seen.has(label)) continue;
  seen.add(label);
  const href = `/year/${y}`;
  const isActive = y === year;
  pills.push({ label: y === currentYear ? `${y} 🔄` : label, href, active: isActive });
}

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${displayLabel} Chinese Internet Memes`,
  "description": `${yearMemes.length} Chinese internet memes from ${displayLabel}, explained in English with cultural context.`,
  "url": `https://cnmemes.com/year/${year}`,
  "hasPart": yearMemes.slice(0, 10).map(m => ({
    "@type": "DefinedTerm",
    "name": m.chinese_name,
    "alternateName": m.english_name,
    "url": `https://cnmemes.com/meme/${m.slug}`
  }))
};
---

<Base
  title={`${displayLabel} Chinese Internet Memes — ${yearMemes.length} Memes Explained`}
  description={`Chinese internet memes from ${displayLabel} explained in English. From ${topMemes} and more — ${yearMemes.length} memes with cultural context and usage examples.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <section class="hero" style="padding-bottom:24px;">
    <h1><span class="cn-part">{displayLabel}</span> Chinese Internet Memes</h1>
    <p>{yearMemes.length} memes from {displayLabel}{isCurrentYear ? ' · Continuously updating 🔄' : ''}</p>
  </section>

  <div class="container">
    <!-- Deduplicated year pills -->
    <div class="year-pills">
      <a href="/" class="year-pill">All</a>
      {pills.map(p => (
        <a href={p.href} class={`year-pill ${p.active ? 'active' : ''}`}>{p.label}</a>
      ))}
    </div>

    <div class="meme-grid">
      {yearMemes.map(m => (
        <MemeCard
          slug={m.slug}
          chinese_name={m.chinese_name}
          english_name={m.english_name}
          pinyin={m.pinyin}
          english_explanation={m.english_explanation}
          year={m.year}
          status={m.status}
          tags={m.tags}
          popularity={m.popularity}
        />
      ))}
    </div>
  </div>
</Base>
