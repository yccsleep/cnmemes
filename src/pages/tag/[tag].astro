---
import Base from '../../layouts/Base.astro';
import MemeCard from '../../components/MemeCard.astro';
import memes from '../../data/memes.json';

export function getStaticPaths() {
  const allTags = new Set<string>();
  memes.forEach(m => m.tags.forEach(t => allTags.add(t)));
  return [...allTags].map(tag => ({
    params: { tag },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const tagMemes = memes.filter(m => m.tags.includes(tag));
const allTags = [...new Set(memes.flatMap(m => m.tags))].sort();
const tagLabel = tag.replace(/-/g, ' ');
const topExamples = tagMemes.filter(m => m.popularity >= 4).slice(0,3).map(m => m.english_name).join(', ');
---

<Base title={`${tagLabel} Chinese Memes — ${tagMemes.length} Memes Explained`} description={`Chinese internet memes about ${tagLabel}. Includes ${topExamples} and ${tagMemes.length - 3} more — each explained in English with cultural context.`}>
  <section class="hero" style="padding-bottom:24px;">
    <h1>Chinese <span class="cn-part">{tagLabel}</span> Memes</h1>
    <p>{tagMemes.length} memes tagged "{tagLabel}" — explained in English</p>
  </section>

  <div class="container">
    <div class="year-pills">
      {allTags.map(t => (
        <a href={`/tag/${t}`} class={`year-pill ${t === tag ? 'active' : ''}`}>{t}</a>
      ))}
    </div>

    <div class="meme-grid">
      {tagMemes.map(m => (
        <MemeCard
          slug={m.slug}
          chinese_name={m.chinese_name}
          english_name={m.english_name}
          pinyin={m.pinyin}
          english_explanation={m.english_explanation}
          year={m.year}
          status={m.status}
          tags={m.tags}
          popularity={m.popularity}
        />
      ))}
    </div>
  </div>
</Base>
