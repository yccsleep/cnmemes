---
import Base from '../layouts/Base.astro';
import MemeCard from '../components/MemeCard.astro';
import memes from '../data/memes.json';

const years = [...new Set(memes.map(m => m.year))].sort((a, b) => b - a);
const totalCount = memes.length;
const currentYear = years[0];

const hotMemes = [...memes]
  .filter(m => m.popularity >= 4)
  .sort((a, b) => b.popularity - a.popularity || b.year - a.year)
  .slice(0, 24);

const sortedMemes = [...memes].sort((a, b) => b.year - a.year || b.popularity - a.popularity);

const statusCounts = {
  classic: memes.filter(m => m.status === 'classic').length,
  popular: memes.filter(m => m.status === 'still popular').length,
  fading: memes.filter(m => m.status === 'fading').length,
};
---

<Base title="Chinese Internet Meme Dictionary" description="Understand Chinese internet memes and viral slang explained in English. Browse 500+ memes from 2015 to today, updated monthly.">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CNMemes — Chinese Meme Dictionary",
    "url": "https://cnmemes.com",
    "description": "The most complete English-language dictionary of Chinese internet memes, from 2015 to today.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://cnmemes.com/?search={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })}></script>

  <!-- Hero -->
  <section class="hero">
    <h1>What Do Chinese Internet Memes Mean?</h1>
    <p>The most complete English guide to Chinese internet memes — from <strong>内卷</strong> (involution) to <strong>yyds</strong> (GOAT), every meme explained with cultural context. Updated monthly.</p>
    <div class="search-box">
      <input type="text" id="searchInput" placeholder="Search memes in Chinese, English, or Pinyin..." autocomplete="off" aria-label="Search Chinese memes" />
    </div>
  </section>

  <div class="container">
    <!-- Year pills -->
    <div class="year-pills">
      <a href="/" class="year-pill active">All</a>
      {years.map(y => (
        <a href={`/year/${y}`} class="year-pill">{y}{y === currentYear ? ' 🔄' : ''}</a>
      ))}
    </div>

    <!-- Hot memes ticker — below year pills -->
    <div class="hot-strip">
      <div class="hot-label">🔥 Trending</div>
      <div class="hot-track-wrap">
        <div class="hot-track">
          {[...hotMemes, ...hotMemes].map(m => (
            <a href={`/meme/${m.slug}`} class="hot-item">
              <span class="hot-cn">{m.chinese_name}</span>
              <span class="hot-en">{m.english_name}</span>
              <span class="hot-stars">{'★'.repeat(m.popularity)}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div style="display:flex;gap:16px;justify-content:center;margin-bottom:36px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);">
        <span class="status-dot classic"></span> {statusCounts.classic} classic
      </div>
      <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);">
        <span class="status-dot popular"></span> {statusCounts.popular} still popular
      </div>
      <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);">
        <span class="status-dot fading"></span> {statusCounts.fading} fading
      </div>
    </div>

    <!-- Meme grid -->
    <div class="meme-grid" id="memeGrid">
      {sortedMemes.map(m => (
        <MemeCard
          slug={m.slug}
          chinese_name={m.chinese_name}
          english_name={m.english_name}
          pinyin={m.pinyin}
          english_explanation={m.english_explanation}
          year={m.year}
          status={m.status}
          tags={m.tags}
          popularity={m.popularity}
        />
      ))}
    </div>
  </div>

  <script define:vars={{ memes: sortedMemes }}>
    const searchInput = document.getElementById('searchInput');
    const grid = document.getElementById('memeGrid');
    const cards = Array.from(grid.children);
    searchInput.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      cards.forEach((card, i) => {
        const m = memes[i];
        const haystack = [m.chinese_name, m.english_name, m.pinyin, m.english_explanation, ...m.tags].join(' ').toLowerCase();
        card.style.display = !q || haystack.includes(q) ? '' : 'none';
      });
    });
  </script>
</Base>

<style>
.hot-strip {
  display: flex;
  align-items: center;
  background: var(--hot-bg);
  border: 1px solid var(--hot-border);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 32px;
}

.hot-label {
  flex-shrink: 0;
  background: var(--accent);
  color: white;
  font-size: 11px;
  font-weight: 700;
  padding: 10px 14px;
  letter-spacing: 1px;
  white-space: nowrap;
  text-transform: uppercase;
}

.hot-track-wrap {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.hot-track-wrap::before,
.hot-track-wrap::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 32px;
  z-index: 1;
  pointer-events: none;
}

.hot-track-wrap::before { left: 0; background: linear-gradient(to right, var(--hot-bg), transparent); }
.hot-track-wrap::after  { right: 0; background: linear-gradient(to left,  var(--hot-bg), transparent); }

.hot-track {
  display: flex;
  width: max-content;
  animation: scroll-left 120s linear infinite;
}

.hot-track:hover { animation-play-state: paused; }

@keyframes scroll-left {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.hot-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  text-decoration: none;
  border-right: 1px solid var(--hot-border);
  white-space: nowrap;
  transition: background 0.2s;
}

.hot-item:hover { background: var(--hot-hover); text-decoration: none; }

.hot-cn   { font-family: 'Noto Serif SC', serif; font-size: 14px; color: var(--hot-cn); font-weight: 700; }
.hot-en   { font-size: 12px; color: var(--text-dim); }
.hot-stars{ font-size: 11px; color: #f0a500; letter-spacing: 1px; }
</style>
