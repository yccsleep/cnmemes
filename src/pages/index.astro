---
import Base from '../layouts/Base.astro';
import MemeCard from '../components/MemeCard.astro';
import memes from '../data/memes.json';

const years = [...new Set(memes.map(m => m.year))].sort((a, b) => b - a);
const totalCount = memes.length;
const currentYear = years[0];

// Build era-aware pill list: group pre-2015 into eras
const eraMap: Record<number, { label: string; slug: string }> = {};
[2002,2003,2004].forEach(y => eraMap[y] = { label: '2000–2004', slug: '2004' });
[2005,2006,2007,2008,2009].forEach(y => eraMap[y] = { label: '2005–2009', slug: '2009' });
[2010,2011,2012,2013,2014].forEach(y => eraMap[y] = { label: '2010–2014', slug: '2014' });

// Build deduplicated pill list
const seenEras = new Set<string>();
const yearPills: { label: string; href: string; count: number }[] = [];
for (const y of years) {
  if (eraMap[y]) {
    const era = eraMap[y];
    if (!seenEras.has(era.label)) {
      seenEras.add(era.label);
      const eraYears = Object.entries(eraMap).filter(([,v]) => v.label === era.label).map(([k]) => Number(k));
      const count = memes.filter(m => eraYears.includes(m.year)).length;
      yearPills.push({ label: era.label, href: `/year/${era.slug}`, count });
    }
  } else {
    const count = memes.filter(m => m.year === y).length;
    yearPills.push({ label: y === currentYear ? `${y} 🔄` : String(y), href: `/year/${y}`, count });
  }
}

const hotMemes = [...memes]
  .filter(m => m.popularity >= 4)
  .sort((a, b) => b.popularity - a.popularity || b.year - a.year)
  .slice(0, 24);

const sortedMemes = [...memes].sort((a, b) => b.year - a.year || b.popularity - a.popularity);

const statusCounts = {
  classic: memes.filter(m => m.status === 'classic').length,
  popular: memes.filter(m => m.status === 'still popular').length,
  fading: memes.filter(m => m.status === 'fading').length,
};
---

<Base title="Chinese Internet Meme Dictionary" description="What do Chinese internet memes mean? Explained in English — 500+ memes from 2015 to today with cultural context. Updated monthly.">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CNMemes — Chinese Meme Dictionary",
    "url": "https://cnmemes.com",
    "description": "The most complete English-language dictionary of Chinese internet memes, from 2015 to today.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://cnmemes.com/?search={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })}></script>

  <!-- Hero -->
  <section class="hero">
    <h1>What Do Chinese Internet Memes Mean?</h1>
    <p>The most complete English guide to Chinese internet memes — from <strong>内卷</strong> (involution) to <strong>yyds</strong> (GOAT), every meme explained with cultural context. Updated monthly.</p>
    <div class="search-box">
      <input type="text" id="searchInput" placeholder="Search memes in Chinese, English, or Pinyin..." autocomplete="off" aria-label="Search Chinese memes" />
    </div>
  </section>

  <div class="container" style="padding-top:24px;">
    <!-- Year pills -->
    <div class="year-pills">
      <a href="/" class="year-pill active">All</a>
      {yearPills.map(p => (
        <a href={p.href} class="year-pill">{p.label}</a>
      ))}
    </div>

    <!-- Hot memes ticker — below year pills -->
    <div class="hot-strip">
      <div class="hot-label">🔥 Trending</div>
      <div class="hot-track-wrap">
        <div class="hot-track">
          {[...hotMemes, ...hotMemes].map(m => (
            <a href={`/meme/${m.slug}`} class="hot-item">
              <span class="hot-cn">{m.chinese_name}</span>
              <span class="hot-en">{m.english_name}</span>
              <span class="hot-stars">{'★'.repeat(m.popularity)}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div style="display:flex;gap:16px;justify-content:center;margin-bottom:36px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);">
        <span class="status-dot classic"></span> {statusCounts.classic} classic
      </div>
      <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);">
        <span class="status-dot popular"></span> {statusCounts.popular} still popular
      </div>
      <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);">
        <span class="status-dot fading"></span> {statusCounts.fading} fading
      </div>
    </div>

    <!-- Meme grid: render first 24 visible, rest hidden at HTML level -->
    <div class="meme-grid" id="memeGrid">
      {sortedMemes.map((m, i) => (
        <div style={i >= 24 ? 'display:none' : ''}>
          <MemeCard
            slug={m.slug}
            chinese_name={m.chinese_name}
            english_name={m.english_name}
            pinyin={m.pinyin}
            english_explanation={m.english_explanation}
            year={m.year}
            status={m.status}
            tags={m.tags}
            popularity={m.popularity}
          />
        </div>
      ))}
    </div>

    <!-- Load more -->
    <div id="loadMoreWrap" style="text-align:center;margin:40px 0 20px;">
      <button id="loadMoreBtn" class="load-more-btn">Load More Memes</button>
      <div id="loadMoreCount" style="font-size:12px;color:var(--text-muted);margin-top:8px;">Showing 24 of {sortedMemes.length}</div>
    </div>
  </div>

  <script define:vars={{ memes: sortedMemes, totalCount: sortedMemes.length }}>
    const searchInput = document.getElementById('searchInput');
    const grid = document.getElementById('memeGrid');
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    const loadMoreWrap = document.getElementById('loadMoreWrap');
    const loadMoreCount = document.getElementById('loadMoreCount');
    const PAGE = 24;
    let showing = PAGE;

    const allWrappers = Array.from(grid.children);

    // Load more
    loadMoreBtn.addEventListener('click', () => {
      const next = Math.min(showing + PAGE, totalCount);
      allWrappers.slice(showing, next).forEach(wrap => {
        wrap.style.display = '';
        wrap.style.animation = 'fadeIn 0.3s ease';
      });
      showing = next;
      loadMoreCount.textContent = `Showing ${showing} of ${totalCount}`;
      if (showing >= totalCount) loadMoreWrap.style.display = 'none';
    });

    // Search
    searchInput.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      if (q) {
        loadMoreWrap.style.display = 'none';
        allWrappers.forEach((wrap, i) => {
          const m = memes[i];
          const haystack = [m.chinese_name, m.english_name, m.pinyin, m.english_explanation, ...m.tags].join(' ').toLowerCase();
          wrap.style.display = haystack.includes(q) ? '' : 'none';
        });
      } else {
        allWrappers.forEach((wrap, i) => { wrap.style.display = i < showing ? '' : 'none'; });
        if (showing < totalCount) loadMoreWrap.style.display = 'block';
      }
    });
  </script>
</Base>

<style>
.load-more-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  color: var(--text-dim);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  padding: 12px 32px;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.18s ease;
  letter-spacing: 0.3px;
}

.load-more-btn:hover {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
  box-shadow: 0 4px 14px rgba(194,59,34,0.3);
  transform: translateY(-1px);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hot-strip {
  display: flex;
  align-items: center;
  background: var(--hot-bg);
  border: 1px solid var(--hot-border);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 32px;
}

.hot-label {
  flex-shrink: 0;
  background: var(--accent);
  color: white;
  font-size: 11px;
  font-weight: 700;
  padding: 10px 14px;
  letter-spacing: 1px;
  white-space: nowrap;
  text-transform: uppercase;
}

.hot-track-wrap {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.hot-track-wrap::before,
.hot-track-wrap::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 32px;
  z-index: 1;
  pointer-events: none;
}

.hot-track-wrap::before { left: 0; background: linear-gradient(to right, var(--hot-bg), transparent); }
.hot-track-wrap::after  { right: 0; background: linear-gradient(to left,  var(--hot-bg), transparent); }

.hot-track {
  display: flex;
  width: max-content;
  animation: scroll-left 180s linear infinite;
}

.hot-track:hover { animation-play-state: paused; }

@keyframes scroll-left {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.hot-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  text-decoration: none;
  border-right: 1px solid var(--hot-border);
  white-space: nowrap;
  transition: background 0.2s;
}

.hot-item:hover { background: var(--hot-hover); text-decoration: none; }

.hot-cn   { font-family: 'Noto Serif SC', serif; font-size: 14px; color: var(--hot-cn); font-weight: 700; }
.hot-en   { font-size: 12px; color: var(--text-dim); }
.hot-stars{ font-size: 11px; color: #f0a500; letter-spacing: 1px; }
</style>
