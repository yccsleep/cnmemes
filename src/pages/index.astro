---
import Base from '../layouts/Base.astro';
import MemeCard from '../components/MemeCard.astro';
import memes from '../data/memes.json';

const totalCount = memes.length;
const currentYear = Math.max(...memes.map(m => m.year));

// 🔥 Trending ticker — what's hot recently: last 3 years + still popular
const hotMemes = [...memes]
  .filter(m => m.year >= currentYear - 2 && m.status === 'still popular')
  .sort((a, b) => b.year - a.year || b.popularity - a.popularity);

// 📚 The Essentials — must-know memes: 5-star + still popular, randomly sampled
const essentialPool = memes.filter(m => m.popularity === 5 && m.status === 'still popular');
const essentials = [...essentialPool].sort(() => Math.random() - 0.5).slice(0, 12);

// 🎭 Browse by Vibe — scenario-based entry points
const vibes = [
  { tag: 'workplace', emoji: '💼', label: 'Work & Burnout', desc: 'Memes your Chinese coworkers live by' },
  { tag: 'romance', emoji: '💔', label: 'Love & Dating', desc: 'How Chinese Gen-Z talks about romance' },
  { tag: 'self-deprecation', emoji: '🙃', label: 'Self-Deprecation', desc: 'The art of roasting yourself' },
  { tag: 'fandom', emoji: '✨', label: 'Fandom & Idols', desc: 'Inside Chinese stan culture' },
  { tag: 'humor', emoji: '🤪', label: 'Pure Absurdism', desc: 'Memes that exist just to be funny' },
  { tag: 'internet-culture', emoji: '🌐', label: 'Internet Culture', desc: 'How the Chinese internet works' },
];

// Full archive — sorted newest first
const allMemes = [...memes].sort((a, b) => b.year - a.year || b.popularity - a.popularity);

// Year sections with representative meme (deduplicated, era-aware, sorted newest first)
const eraLabels: Record<number, string> = { 2004: '2000–2004', 2009: '2005–2009', 2014: '2010–2014' };
const pageYearOf = (y: number) => y >= 2015 ? y : y <= 2004 ? 2004 : y <= 2009 ? 2009 : 2014;
interface YearSection { label: string; href: string; rep: (typeof memes)[0]; }
const yearSections: YearSection[] = [];
const seenYears = new Set<number>();
for (const y of [...new Set(memes.map(m => m.year))].sort((a, b) => b - a)) {
  const py = pageYearOf(y);
  if (seenYears.has(py)) continue;
  seenYears.add(py);
  const rep = [...memes]
    .filter(m => pageYearOf(m.year) === py)
    .sort((a, b) => b.popularity - a.popularity || (b.status === 'still popular' ? 1 : 0) - (a.status === 'still popular' ? 1 : 0))[0];
  yearSections.push({ label: eraLabels[py] ?? String(py), href: `/year/${py}`, rep });
}
---

<Base title="Chinese Internet Memes Explained in English" description="What do Chinese internet memes mean? 500+ memes and slang terms explained in English with cultural context — from 内卷 to yyds, 2000 to today.">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CNMemes — Chinese Meme Dictionary",
    "url": "https://cnmemes.com",
    "description": "The most complete English-language dictionary of Chinese internet memes, from 2000 to today.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://cnmemes.com/?search={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })}></script>

  <!-- Hero -->
  <section class="hero">
    <h1>What Do Chinese Internet Memes Mean?</h1>
    <p>The most complete English guide to Chinese internet memes — from <strong>内卷</strong> (involution) to <strong>yyds</strong> (GOAT), every meme explained with cultural context.</p>
    <div class="search-box">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" id="searchInput" placeholder="Search 500+ memes in Chinese, English, or Pinyin..." autocomplete="off" aria-label="Search Chinese memes" />
    </div>
  </section>

  <!-- 🔥 Trending ticker -->
  <div class="container" style="padding-top:20px;padding-bottom:12px;">
    <div class="hot-strip">
      <div class="hot-label">🔥 Trending</div>
      <div class="hot-track-wrap">
        <div class="hot-track">
          {[...hotMemes, ...hotMemes].map(m => (
            <a href={`/meme/${m.slug}`} class="hot-item">
              <span class="hot-cn">{m.chinese_name}</span>
              <span class="hot-en">{m.english_name}</span>
              <span class="hot-stars">{'★'.repeat(m.popularity)}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Search results (hidden until search) -->
  <div class="container" id="searchResultsWrap" style="display:none;">
    <h2 class="section-heading"><span id="searchCount">0</span> results</h2>
    <div class="meme-grid" id="searchResults"></div>
    <div id="noResults" style="display:none;text-align:center;padding:40px;color:var(--text-muted);">
      No memes found. Try a different search term.
    </div>
  </div>

  <!-- Default curated content (hidden during search) -->
  <div id="curatedContent">

    <!-- 📚 The Essentials -->
    <section class="container home-section">
      <div class="section-head">
        <div>
          <h2 class="section-heading">📚 The Essentials — Must-Know Chinese Memes</h2>
          <p class="section-sub">Start here — the hand-picked memes that define today's Chinese internet.</p>
        </div>
      </div>
      <div class="meme-grid">
        {essentials.map(m => (
          <MemeCard
            slug={m.slug} chinese_name={m.chinese_name} english_name={m.english_name}
            pinyin={m.pinyin} english_explanation={m.english_explanation}
            year={m.year} status={m.status} tags={m.tags} popularity={m.popularity}
          />
        ))}
      </div>
      <div class="section-more">
        <a href="/top-memes" class="section-more-btn">See all top memes →</a>
      </div>
    </section>

    <!-- 🎭 Browse by Vibe -->
    <div class="section-band">
      <section class="container home-section" style="margin-bottom:0;padding-top:48px;padding-bottom:48px;">
        <div class="section-head">
          <div>
            <h2 class="section-heading">🎭 Browse by Vibe — Chinese Memes by Theme</h2>
            <p class="section-sub">Jump into the corner of Chinese internet culture you're curious about.</p>
          </div>
        </div>
        <div class="vibe-grid">
          {vibes.map(v => (
            <a href={`/tag/${v.tag}`} class="vibe-card">
              <span class="vibe-emoji">{v.emoji}</span>
              <span class="vibe-label">{v.label}</span>
              <span class="vibe-desc">{v.desc}</span>
            </a>
          ))}
        </div>

      </section>
    </div>

    <!-- Browse all — by year -->
    <section class="container home-section" style="padding-top:48px;">
      <div class="section-head">
        <div>
          <h2 class="section-heading">📖 Browse All — Chinese Memes by Year</h2>
          <p class="section-sub">Explore the full archive by year — from the BBS era to today.</p>
        </div>
      </div>
      <div class="year-sections-grid">
        {yearSections.map(ys => (
          <div class="year-section">
            <a href={ys.href} class="year-section-label">
              <span class="year-num">{ys.label}</span>
              <span class="year-badge">Meme of the Year</span>
            </a>
            <MemeCard {...ys.rep} />
          </div>
        ))}
      </div>
      <div class="section-more">
        <a href="/top-memes" class="section-more-btn">Browse all top memes →</a>
      </div>
    </section>

  </div>

  <script define:vars={{ allMemes, totalCount }}>
    const searchInput = document.getElementById('searchInput');
    const curated = document.getElementById('curatedContent');
    const searchWrap = document.getElementById('searchResultsWrap');
    const searchResults = document.getElementById('searchResults');
    const searchCount = document.getElementById('searchCount');
    const noResults = document.getElementById('noResults');

    // Search
    function escapeHtml(s) {
      return s.replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
    }
    function eraLabel(y) {
      if (y >= 2015) return String(y);
      if (y <= 2004) return '2000–2004';
      if (y <= 2009) return '2005–2009';
      return '2010–2014';
    }
    function pageYearOf(y) {
      return y >= 2015 ? y : y <= 2004 ? 2004 : y <= 2009 ? 2009 : 2014;
    }

    searchInput.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      if (!q) {
        curated.style.display = '';
        searchWrap.style.display = 'none';
        return;
      }
      curated.style.display = 'none';
      searchWrap.style.display = '';

      const matched = allMemes.filter(m => {
        const hay = [m.chinese_name, m.english_name, m.pinyin, m.english_explanation, ...m.tags].join(' ').toLowerCase();
        return hay.includes(q);
      });

      searchCount.textContent = matched.length;
      if (matched.length === 0) {
        searchResults.innerHTML = '';
        noResults.style.display = 'block';
        return;
      }
      noResults.style.display = 'none';

      const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
      searchResults.innerHTML = matched.map(m => {
        const statusClass = m.status === 'still popular' ? 'popular' : m.status === 'fading' ? 'fading' : 'classic';
        const stars = '★'.repeat(m.popularity) + '☆'.repeat(5 - m.popularity);
        const excerpt = escapeHtml(m.english_explanation).replace(re, '<mark class="search-hl">$1</mark>');
        const py = pageYearOf(m.year);
        return `
          <div class="meme-card-wrap">
            <a href="/meme/${m.slug}" class="meme-card">
              <div class="card-cn">${m.chinese_name}</div>
              <div class="card-en">${escapeHtml(m.english_name)}</div>
              <div class="card-pinyin">${m.pinyin}</div>
              <div class="card-excerpt">${excerpt}</div>
            </a>
            <div class="card-meta">
              <a href="/year/${py}" class="tag tag-year">${eraLabel(m.year)}</a>
              <span class="tag tag-${statusClass}">${m.status}</span>
              <span class="popularity-stars">${stars}</span>
            </div>
          </div>`;
      }).join('');
    });
  </script>
</Base>

<style>
/* Archive year navigation */
.year-sections-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
  margin-bottom: 24px;
}

.year-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-left: 14px;
  border-left: 3px solid var(--accent);
}

.year-section-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-decoration: none;
  color: var(--text);
  transition: color 0.16s ease;
}

.year-section-label:hover { color: var(--accent); text-decoration: none; }

.year-num {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 900;
  color: inherit;
  line-height: 1;
}

.year-badge {
  font-size: 11px;
  font-weight: 700;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.7px;
  background: rgba(194, 59, 34, 0.07);
  padding: 3px 9px;
  border-radius: 20px;
  border: 1px solid var(--accent-border);
  white-space: nowrap;
}

@media (max-width: 480px) {
  .year-sections-grid { grid-template-columns: 1fr; }
}

/* Section background band */
.section-band {
  background: var(--bg-subtle);
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
  margin: 8px 0;
}

.home-section { margin-bottom: 56px; }

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20px;
}

.section-heading {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 700;
  color: var(--text);
}

.section-sub {
  font-size: 14px;
  color: var(--text-dim);
  margin-top: 4px;
}

.section-more {
  text-align: center;
  margin-top: 24px;
}

.section-more-btn {
  display: inline-block;
  font-size: 14px;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  padding: 8px 20px;
  border: 1.5px solid var(--accent-border);
  border-radius: 50px;
  transition: all 0.18s ease;
}
.section-more-btn:hover {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
  text-decoration: none;
}

/* Vibe grid */
.vibe-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
}

.vibe-card {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 20px 22px;
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: all 0.18s ease;
}
.vibe-card:hover {
  border-color: var(--accent-border);
  transform: translateY(-3px);
  box-shadow: var(--shadow);
  text-decoration: none;
}

.vibe-emoji { font-size: 28px; }
.vibe-label {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
}
.vibe-desc {
  font-size: 13px;
  color: var(--text-dim);
  line-height: 1.5;
}

/* Search highlight */
mark.search-hl {
  background: rgba(194, 59, 34, 0.15);
  color: var(--accent);
  border-radius: 2px;
  padding: 0 1px;
  font-weight: 600;
}

/* Trending ticker */
.hot-strip {
  display: flex;
  align-items: center;
  background: var(--hot-bg);
  border: 1.5px solid var(--hot-border);
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 8px;
  box-shadow: var(--shadow-sm);
}
.hot-label {
  flex-shrink: 0;
  background: var(--accent);
  color: white;
  font-size: 11px;
  font-weight: 700;
  padding: 10px 14px;
  letter-spacing: 1px;
  white-space: nowrap;
  text-transform: uppercase;
}
.hot-track-wrap {
  flex: 1;
  overflow: hidden;
  position: relative;
}
.hot-track-wrap::before,
.hot-track-wrap::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 32px;
  z-index: 1;
  pointer-events: none;
}
.hot-track-wrap::before { left: 0; background: linear-gradient(to right, var(--hot-bg), transparent); }
.hot-track-wrap::after  { right: 0; background: linear-gradient(to left,  var(--hot-bg), transparent); }
.hot-track {
  display: flex;
  width: max-content;
  animation: scroll-left 180s linear infinite;
}
.hot-track:hover { animation-play-state: paused; }
@keyframes scroll-left {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.hot-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  text-decoration: none;
  border-right: 1px solid var(--hot-border);
  white-space: nowrap;
  transition: background 0.2s;
}
.hot-item:hover { background: var(--hot-hover); text-decoration: none; }
.hot-cn   { font-family: 'Noto Serif SC', serif; font-size: 14px; color: var(--hot-cn); font-weight: 700; }
.hot-en   { font-size: 12px; color: var(--text-dim); }
.hot-stars{ font-size: 11px; color: #f0a500; letter-spacing: 1px; }

@media (max-width: 768px) {
  .section-heading { font-size: 21px; }
  .home-section { margin-bottom: 44px; }
}

@media (max-width: 480px) {
  .hot-en { display: none; }
  .hot-item { padding: 10px 12px; gap: 6px; }
  .vibe-grid { grid-template-columns: 1fr; }
}
</style>
