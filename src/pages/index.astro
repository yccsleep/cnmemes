---
import Base from '../layouts/Base.astro';
import MemeCard from '../components/MemeCard.astro';
import memes from '../data/memes.json';
import imageMemes from '../data/image-memes.json';
import platforms from '../data/platforms.json';

const totalCount = memes.length;
const currentYear = Math.max(...memes.map(m => m.year));

// platforms computed after yearSections (below)

// 🔥 Trending ticker — what's hot recently: last 3 years + still popular
const hotMemes = [...memes]
  .filter(m => m.year >= currentYear - 2 && m.status === 'still popular')
  .sort((a, b) => b.year - a.year || b.popularity - a.popularity);

// 📚 The Essentials — curated gateway memes for English-speaking newcomers
const essentialSlugs = [
  'nei-juan',          // 内卷 — involution, the defining concept
  'tang-ping',         // 躺平 — lying flat, the counter-movement
  'yong-yuan-de-shen', // yyds — the most-used superlative
  'da-gong-ren',       // 打工人 — worker identity
  'bai-lan',           // 摆烂 — let it rot / quiet quitting
  'zhen-xiang',        // 真香 — eating your words
  'cao-tai-ban-zi',    // 草台班子 — imposter syndrome at scale
  'fan-er-sai',        // 凡尔赛 — humble bragging Versailles-style
  'chi-gua-qunzhong',  // 吃瓜群众 — popcorn-eating bystanders
  'fo-xi',             // 佛系 — Buddhist-mode / radical chill
];
const essentialMap = Object.fromEntries(memes.map(m => [m.slug, m]));
const essentials = essentialSlugs.map(s => essentialMap[s]).filter(Boolean);

// 🎭 Browse by Vibe — scenario-based entry points
const vibes = [
  { tag: 'workplace', label: 'Work & Burnout', desc: 'Memes your Chinese coworkers live by',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>` },
  { tag: 'romance', label: 'Love & Dating', desc: 'How Chinese Gen-Z talks about romance',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>` },
  { tag: 'self-deprecation', label: 'Self-Deprecation', desc: 'The art of roasting yourself',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 15s1.5-2 4-2 4 2 4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>` },
  { tag: 'fandom', label: 'Fandom & Idols', desc: 'Inside Chinese stan culture',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>` },
  { tag: 'humor', label: 'Pure Absurdism', desc: 'Memes that exist just to be funny',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>` },
  { tag: 'internet-culture', label: 'Internet Culture', desc: 'How the Chinese internet works',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>` },
];

// Full archive — sorted newest first, slim payload for client search
const allMemes = [...memes]
  .sort((a, b) => b.year - a.year || b.popularity - a.popularity)
  .map(({ slug, chinese_name, english_name, pinyin, english_explanation, year, status, tags, popularity }) =>
    ({ slug, chinese_name, english_name, pinyin, english_explanation, year, status, tags, popularity }));

// Image memes for search — slim payload
const allImageMemes = [...imageMemes]
  .map(({ slug, chinese_name, english_name, pinyin, year, status, tags, popularity }) =>
    ({ slug, chinese_name, english_name, pinyin, year, status, tags, popularity, _type: 'image' }));

// Image meme sidebar preview — random each build
const imageMemePreview = [...imageMemes]
  .sort(() => Math.random() - 0.5)
  .slice(0, 5);

// Year sections with representative meme (deduplicated, era-aware, sorted newest first)
const eraLabels: Record<number, string> = { 2004: '2000–2004', 2009: '2005–2009', 2014: '2010–2014' };
const pageYearOf = (y: number) => y >= 2015 ? y : y <= 2004 ? 2004 : y <= 2009 ? 2009 : 2014;
interface YearSection { label: string; href: string; rep: (typeof memes)[0]; }
const yearSections: YearSection[] = [];
const seenYears = new Set<number>();
for (const y of [...new Set(memes.map(m => m.year))].sort((a, b) => b - a)) {
  const py = pageYearOf(y);
  if (seenYears.has(py)) continue;
  seenYears.add(py);
  const rep = [...memes]
    .filter(m => pageYearOf(m.year) === py)
    .sort((a, b) => b.popularity - a.popularity || (b.status === 'still popular' ? 1 : 0) - (a.status === 'still popular' ? 1 : 0))[0];
  yearSections.push({ label: eraLabels[py] ?? String(py), href: `/year/${py}`, rep });
}

// Show only as many platform cards as rows in the year grid (2-column grid)
const platformRowCount = Math.ceil(yearSections.length / 2);
const platformsWithCounts = [...platforms]
  .sort((a, b) => (b.meme_count || 0) - (a.meme_count || 0))
  .slice(0, platformRowCount)
  .map(p => ({ ...p, memeCount: p.meme_count || 0 }));
---

<Base title="Chinese Internet Memes Dictionary | 496+ Memes Explained" description="496 Chinese internet memes explained in English 中文梗典 — From 内卷 to yyds, cultural context for every meme (2000-2026)">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CNMemes — Chinese Meme Dictionary",
    "url": "https://cnmemes.com",
    "description": "The most complete English-language dictionary of Chinese internet memes, from 2000 to today.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://cnmemes.com/?search={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })}></script>

  <!-- Hero -->
  <section class="hero">
    <h1>What Do Chinese Internet Memes Mean?</h1>
    <p>The most complete English guide to Chinese internet memes — from <strong>内卷</strong> (involution) to <strong>yyds</strong> (GOAT), every meme explained with cultural context.</p>
    <div class="search-box">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" id="searchInput" placeholder="Try: 内卷, yyds, 躺平, 凡尔赛..." autocomplete="off" aria-label="Search Chinese memes" />
    </div>
  </section>

  <!-- 🔥 Trending ticker -->
  <div class="container" style="padding-top:40px;padding-bottom:56px;">
    <div class="hot-strip">
      <div class="hot-label">🔥 Trending</div>
      <div class="hot-track-wrap">
        <div class="hot-track">
          {[...hotMemes, ...hotMemes].map(m => (
            <a href={`/meme/${m.slug}`} class="hot-item">
              <span class="hot-cn">{m.chinese_name}</span>
              <span class="hot-en">{m.english_name}</span>
              <span class="hot-stars">{'★'.repeat(m.popularity)}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Leaderboard Ad (728x90) -->
  <div class="ad-container ad-leaderboard">
    <ins class="adsbygoogle"
         style="display:inline-block;width:728px;height:90px"
         data-ad-client="ca-pub-9126709577750935"
         data-ad-slot="homepage-leaderboard"></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>

  <!-- Search results (full width, hidden until search) -->
  <div class="container" id="searchResultsWrap" style="display:none;">
    <h2 class="section-heading" style="padding-top:32px;"><span id="searchCount">0</span> results</h2>
    <div class="meme-grid" id="searchResults"></div>
    <div id="noResults" style="display:none;text-align:center;padding:48px 24px;"></div>
  </div>

  <!-- Default curated content -->
  <div id="curatedContent">

    <!-- 2-col: The Essentials (left) + Image Memes (right) -->
    <div class="container essentials-layout">

      <!-- Left: The Essentials -->
      <section class="home-section">
        <div class="section-head">
          <div>
            <h2 class="section-heading">The Essentials</h2>
            <p class="section-sub">10 memes every English speaker should know — with cultural context, not just translation.</p>
          </div>
        </div>
        <div class="meme-grid">
          {essentials.map(m => (
            <MemeCard
              slug={m.slug} chinese_name={m.chinese_name} english_name={m.english_name}
              pinyin={m.pinyin} english_explanation={m.english_explanation}
              year={m.year} status={m.status} tags={m.tags} popularity={m.popularity}
            />
          ))}
        </div>
        <div class="section-more">
          <a href="/top-memes" class="section-more-btn">See all top memes →</a>
        </div>
      </section>

      <!-- Right: Image Memes sidebar -->
      <aside class="image-sidebar">
        <div class="home-section">
          <div class="section-head">
            <div>
              <h2 class="section-heading">Image Memes</h2>
              <p class="section-sub">The visual language of Chinese social media.</p>
            </div>
          </div>
          <div class="image-sidebar-grid">
            {imageMemePreview.map(m => {
              const sc = m.status === 'still popular' ? 'popular' : m.status === 'fading' ? 'fading' : 'classic';
              const st = '★'.repeat(m.popularity) + '☆'.repeat(5 - m.popularity);
              return (
                <a href={`/image-meme/${m.slug}`} class="sb-card">
                  <img src={m.image} alt={`${m.chinese_name} — ${m.english_name} Chinese internet meme`} loading="lazy" class="sb-bg-img" />
                  <div class="sb-overlay"></div>
                  <div class="sb-card-content">
                    <div class="sb-card-cn">{m.chinese_name}</div>
                    <div class="sb-card-en">{m.english_name}</div>
                    <div class="sb-card-meta">
                      <span class="sb-tag-year">{m.year}</span>
                      <span class={`sb-tag-status sb-tag-${sc}`}>{m.status}</span>
                      {m.tags.slice(0, 1).map(t => (
                        <span class="sb-tag-topic">{t}</span>
                      ))}
                      <span class="sb-stars">{st}</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
          <div class="section-more">
            <a href="/image-memes" class="section-more-btn">Browse all image memes →</a>
          </div>
        </div>
      </aside>

    </div>

    <!-- 2-col: Browse by Year (left 2/3) + All Platforms (right 1/3) -->
    <div class="container browse-layout">

      <!-- Left 2/3: Browse by Year -->
      <section class="browse-left home-section">
        <div class="section-head">
          <div>
            <h2 class="section-heading">Browse by Year</h2>
            <p class="section-sub">From China's earliest internet jokes to today — every meme, every year.</p>
          </div>
        </div>
        <div class="year-sections-grid">
          {yearSections.map(ys => {
            const m = ys.rep;
            const sc = m.status === 'still popular' ? 'popular' : m.status === 'fading' ? 'fading' : 'classic';
            const stars = '★'.repeat(m.popularity) + '☆'.repeat(5 - m.popularity);
            return (
              <a href={ys.href} class="year-card">
                <div class="year-card-header">
                  <span class="year-card-num">{ys.label}</span>
                  <span class="year-card-badge">Top Pick</span>
                </div>
                <div class="year-card-body">
                  <div class="year-card-cn">{m.chinese_name}</div>
                  <div class="year-card-en">{m.english_name}</div>
                  <div class="year-card-pinyin">{m.pinyin}</div>
                </div>
                <div class="year-card-meta">
                  <span class={`tag tag-${sc}`}>{m.status}</span>
                  {m.tags.slice(0, 1).map(t => <span class="tag tag-topic">{t}</span>)}
                  <span class="year-card-stars">{stars}</span>
                </div>
              </a>
            );
          })}
        </div>
        <div class="section-more">
          <a href="/memes" class="section-more-btn">Browse all memes →</a>
        </div>
      </section>

      <!-- Right 1/3: All Platforms -->
      <aside class="platforms-sidebar">
        <div class="home-section">
          <div class="section-head">
            <div>
              <h2 class="section-heading">Platforms</h2>
              <p class="section-sub">Where Chinese memes are born.</p>
            </div>
          </div>
          <div class="platforms-grid">
            {platformsWithCounts.map(p => (
              <a href={`/platform/${p.slug}`} class="platform-card" style={`--p-color:${p.color};`}>
                <div class="platform-card-main">
                  <div class="platform-card-top">
                    <div class="platform-names">
                      <span class="platform-cn">{p.chinese_name}</span>
                      <span class="platform-en">{p.english_name}</span>
                    </div>
                    <span class={`platform-status-badge status-${p.status}`}>{p.status}</span>
                  </div>
                  <div class="platform-meta">
                    <span class="platform-type">{p.type}</span>
                    <span class="platform-years">Est. {p.founded} · Peak: {p.peak_years}</span>
                  </div>
                  <div class="platform-footer">
                    <span class="platform-count">{p.memeCount} memes</span>
                    <span class="platform-link-arrow">Explore →</span>
                  </div>
                </div>
                <div class="platform-card-logo">
                  <div class="platform-card-logo-wrap">
                    <svg viewBox="0 0 24 24" class="platform-card-logo-icon" aria-hidden="true" set:html={`<path fill-rule="evenodd" d="${p.icon_path}"/>`} />
                  </div>
                </div>
              </a>
            ))}
          </div>
          <div class="section-more">
            <a href="/platforms" class="section-more-btn">All platforms →</a>
          </div>
        </div>
      </aside>

    </div>

    <!-- Browse by Vibe — full container width -->
    <div class="container">
      <section class="home-section">
        <div class="section-head">
          <div>
            <h2 class="section-heading">Browse by Vibe</h2>
            <p class="section-sub">What mood are you in? Explore memes by theme.</p>
          </div>
        </div>
        <div class="vibe-grid">
          {vibes.map(v => (
            <a href={`/tag/${v.tag}`} class="vibe-card">
              <span class="vibe-icon" set:html={v.icon} />
              <span class="vibe-text">
                <span class="vibe-label">{v.label}</span>
                <span class="vibe-desc">{v.desc}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    </div>

  </div>

  <script>
    function syncSidebarHeights() {
      const leftCards = Array.from(document.querySelectorAll(
        '.essentials-layout > section .meme-card-wrap'
      ));
      const rightCards = Array.from(document.querySelectorAll(
        '.image-sidebar-grid .sb-card'
      ));
      if (!leftCards.length || !rightCards.length) return;

      // Reset first
      rightCards.forEach(c => c.style.minHeight = '');

      // Group left cards into rows by offsetTop
      const rows = [];
      let prevTop = -999;
      let row = [];
      leftCards.forEach(card => {
        const top = card.getBoundingClientRect().top;
        if (top > prevTop + 5) {
          if (row.length) rows.push(row);
          row = [card];
          prevTop = top;
        } else {
          row.push(card);
        }
      });
      if (row.length) rows.push(row);

      // Apply each row's max height to the corresponding right card
      rows.forEach((r, i) => {
        if (i >= rightCards.length) return;
        const h = Math.max(...r.map(c => c.offsetHeight));
        rightCards[i].style.minHeight = h + 'px';
      });
    }

    document.fonts.ready.then(syncSidebarHeights);
    setTimeout(syncSidebarHeights, 1500);

    let resizeTimer;
    window.addEventListener('resize', () => {
      document.querySelectorAll('.image-sidebar-grid .sb-card')
        .forEach(c => c.style.minHeight = '');
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(syncSidebarHeights, 100);
    });
  </script>

  <script>
    // Sync platform card heights to match year grid row heights
    function syncPlatformHeights() {
      const yearCards = Array.from(document.querySelectorAll('.year-sections-grid .year-card'));
      const platformCards = Array.from(document.querySelectorAll('.platforms-grid .platform-card'));
      if (!yearCards.length || !platformCards.length) return;

      // Reset
      platformCards.forEach(c => { c.style.height = ''; });

      // Group year cards into rows by offsetTop
      const rows = [];
      let prevTop = -1;
      let row = [];
      yearCards.forEach(card => {
        const top = card.offsetTop;
        if (top > prevTop + 5) {
          if (row.length) rows.push(row);
          row = [card];
          prevTop = top;
        } else {
          row.push(card);
        }
      });
      if (row.length) rows.push(row);

      // Apply each row's height to the corresponding platform card
      rows.forEach((row, i) => {
        if (i >= platformCards.length) return;
        platformCards[i].style.height = row[0].offsetHeight + 'px';
      });
    }

    document.fonts.ready.then(syncPlatformHeights);
    setTimeout(syncPlatformHeights, 1500);

    let platformResizeTimer;
    window.addEventListener('resize', () => {
      document.querySelectorAll('.platforms-grid .platform-card').forEach(c => { c.style.height = ''; });
      clearTimeout(platformResizeTimer);
      platformResizeTimer = setTimeout(syncPlatformHeights, 100);
    });
  </script>

  <script define:vars={{ allMemes, allImageMemes, totalCount }}>
    const searchInput = document.getElementById('searchInput');
    const curated = document.getElementById('curatedContent');
    const searchWrap = document.getElementById('searchResultsWrap');
    const searchResults = document.getElementById('searchResults');
    const searchCount = document.getElementById('searchCount');
    const noResults = document.getElementById('noResults');

    // Search
    function escapeHtml(s) {
      return s.replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
    }
    function eraLabel(y) {
      if (y >= 2015) return String(y);
      if (y <= 2004) return '2000–2004';
      if (y <= 2009) return '2005–2009';
      return '2010–2014';
    }
    function pageYearOf(y) {
      return y >= 2015 ? y : y <= 2004 ? 2004 : y <= 2009 ? 2009 : 2014;
    }

    searchInput.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      if (!q) {
        curated.style.display = '';
        searchWrap.style.display = 'none';
        return;
      }
      curated.style.display = 'none';
      searchWrap.style.display = '';

      const matched = allMemes.filter(m => {
        const hay = [m.chinese_name, m.english_name, m.pinyin, m.english_explanation, ...m.tags].join(' ').toLowerCase();
        return hay.includes(q);
      });
      const matchedImage = allImageMemes.filter(m => {
        const hay = [m.chinese_name, m.english_name, m.pinyin, ...(m.tags||[])].join(' ').toLowerCase();
        return hay.includes(q);
      });
      const allMatched = [...matched, ...matchedImage];

      searchCount.textContent = allMatched.length;
      if (allMatched.length === 0) {
        searchResults.innerHTML = '';
        const safe = escapeHtml(e.target.value.trim());
        const mailto = `mailto:whycici@gmail.com?subject=${encodeURIComponent('Meme Request: ' + e.target.value.trim())}&body=${encodeURIComponent(`Hi,\n\nI searched for "${e.target.value.trim()}" on cnmemes.com but it wasn't in the dictionary yet.\n\nCould you add it?\n\nThanks!`)}`;
        noResults.innerHTML = `
          <p class="no-results-title">No results for "<strong>${safe}</strong>"</p>
          <p class="no-results-sub">Looks like we haven't covered this one yet.</p>
          <a href="${mailto}" class="submit-meme-btn">Submit "${safe}" for review →</a>
          <p class="no-results-note">We'll review and aim to add it within a few days.</p>
        `;
        noResults.style.display = 'block';
        return;
      }
      noResults.style.display = 'none';

      const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');

      const textCards = matched.map(m => {
        const statusClass = m.status === 'still popular' ? 'popular' : m.status === 'fading' ? 'fading' : 'classic';
        const stars = '★'.repeat(m.popularity) + '☆'.repeat(5 - m.popularity);
        const excerpt = escapeHtml(m.english_explanation).replace(re, '<mark class="search-hl">$1</mark>');
        const py = pageYearOf(m.year);
        return `
          <div class="meme-card-wrap">
            <a href="/meme/${m.slug}" class="meme-card">
              <div class="card-cn">${m.chinese_name}</div>
              <div class="card-en">${escapeHtml(m.english_name)}</div>
              <div class="card-pinyin">${m.pinyin}</div>
              <div class="card-excerpt">${excerpt}</div>
            </a>
            <div class="card-meta">
              <div class="card-meta-tags">
                <a href="/year/${py}" class="tag tag-year">${eraLabel(m.year)}</a>
                <span class="tag tag-${statusClass}">${m.status}</span>
              </div>
              <span class="popularity-stars">${stars}</span>
            </div>
          </div>`;
      });

      const imageCards = matchedImage.map(m => {
        const statusClass = m.status === 'still popular' ? 'popular' : m.status === 'fading' ? 'fading' : 'classic';
        const stars = '★'.repeat(m.popularity) + '☆'.repeat(5 - m.popularity);
        return `
          <div class="meme-card-wrap">
            <a href="/image-meme/${m.slug}" class="meme-card">
              <div class="card-cn">${m.chinese_name}</div>
              <div class="card-en">${escapeHtml(m.english_name)} <span style="font-size:10px;color:var(--text-muted);font-weight:400;">· Image Meme</span></div>
              <div class="card-pinyin">${m.pinyin}</div>
            </a>
            <div class="card-meta">
              <div class="card-meta-tags">
